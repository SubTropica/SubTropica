Notebook[{

Cell[CellGroupData[{
Cell["SubTropica", "GuideTitle",ExpressionUUID->"ef1dc647-beae-4f1c-996a-3c5b0d06cb70"],

Cell["\<\
Feynman-integral evaluation via tropical geometry. SubTropica automates the \
full pipeline from a Feynman graph to an analytic result: Symanzik polynomial \
construction, GL(1) gauge fixing, Nilsson\[Dash]Passare tropical subtraction, \
linear-reducibility analysis, and integration via HyperIntica. Analytic \
results can be cross-checked numerically against pySecDec, FIESTA, AMFlow, or \
feyntrop. Install and configure external tools once with ConfigureSubTropica, \
then evaluate integrals either through STIntegrate (scripted) or \
FeynmanIntegrate (interactive GUI).\
\>", "GuideAbstract",ExpressionUUID->"befd5c04-d309-48cb-b41c-d3b114e3f600"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Installation", "GuideFunctionsSection",ExpressionUUID->"14bc13aa-2aba-450d-b017-62de86e059e5"],

Cell["Install the paclet from Mathematica:", "GuideText",ExpressionUUID->"089b5041-6226-41f0-9d8f-aae073d0307c"],

Cell[BoxData[
 RowBox[{"PacletInstall", "[", "\"\<https://subtropi.ca/SubTropica.paclet\>\"",
   "]"}]], "Input",ExpressionUUID->"351bc013-d256-4083-b523-67b3ea1c1cba"],

Cell["Then load it and configure external-tool paths:", "GuideText",ExpressionUUID->"bfbe1d0c-f210-4330-8a65-a67e8b391f52"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"Get", "[", "\"\<SubTropica`\>\"", "]"}], ";"}], "\n", 
 RowBox[{"ConfigureSubTropica", "[", "\n", "  ", 
  RowBox[{"(*", " ", "required", " ", "*)"}], "\n", "  ", 
  RowBox[{
   RowBox[{"PolymakePath", "   ", "->", " ", "\"\<path/to/polymake\>\""}], ",",
    "\n", "  ", 
   RowBox[{"(*", " ", "recommended", " ", "*)"}], "\n", "  ", 
   RowBox[{"FiniteFlowPath", " ", "->", " ", "\"\<path/to/FiniteFlow\>\""}], ",",
    "\n", "  ", 
   RowBox[{"SPQRPath", "       ", "->", " ", "\"\<path/to/SPQR\>\""}], ",", 
   "\n", "  ", 
   RowBox[{"PythonPath", "     ", "->", " ", "\"\<path/to/python\>\""}], ",", 
   "\n", "  ", 
   RowBox[{"(*", " ", "optional", " ", "*)"}], "\n", "  ", 
   RowBox[{"GinshPath", "      ", "->", " ", "\"\<path/to/ginsh\>\""}], ",", 
   "\n", "  ", 
   RowBox[{"MaplePath", "      ", "->", " ", "\"\<path/to/maple\>\""}], ",", 
   "\n", "  ", 
   RowBox[{"pySecDecPath", "   ", "->", " ", "\"\<path/to/pySecDec\>\""}], ",",
    "\n", "  ", 
   RowBox[{"FIESTAPath", "     ", "->", " ", "\"\<path/to/FIESTA\>\""}]}], 
  "\n", "]"}]}], "Input",ExpressionUUID->"d55e4d8e-1401-4853-8fe0-\
d9f5c14680d5"],

Cell[TextData[{
 "Paths are written to the persistent config file (",
 StyleBox["$UserBaseDirectory/Kernel/SubTropicaConfig.m", "TI"],
 ") and reapplied on every subsequent ",
 StyleBox["Get[\"SubTropica`\"]", "TI"],
 "; call ",
 StyleBox["ConfigureSubTropica", "TI"],
 " only to add or change a path.  Use ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["STResetConfig"]], "paclet:SubTropica/ref/STResetConfig", 
    "SubTropica Package Symbol"},
   "PackageLink",
   BaseStyle->"InlineFunctionSans"]], "InlineFunctionSans",ExpressionUUID->
  "be4282ed-c81e-425f-9867-845ca358e1e7"],
 " to discard the saved configuration."
}], "GuideText",ExpressionUUID->"48c9e9a8-3e34-4a27-aa0e-a857242a076a"],

Cell[TextData[{
 StyleBox["polymake", "TI"],
 " is the only required dependency.  ",
 StyleBox["python", "TI"],
 " is strongly recommended (required for the GUI).  ",
 StyleBox["FiniteFlow", "TI"],
 " and ",
 StyleBox["SPQR", "TI"],
 " enable finite-field arithmetic inside HyperIntica's partial-fraction step \
and are recommended for complex diagrams.  ",
 StyleBox["pySecDec", "TI"],
 ", ",
 StyleBox["FIESTA", "TI"],
 ", ",
 StyleBox["AMFlow", "TI"],
 ", ",
 StyleBox["feyntrop", "TI"],
 " enable numerical cross-checks via ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["STVerify"]], "paclet:SubTropica/ref/STVerify", 
    "SubTropica Package Symbol"},
   "PackageLink",
   BaseStyle->"InlineFunctionSans"]], "InlineFunctionSans",ExpressionUUID->
  "8573a6c8-5d3d-44dd-a916-4ea0b34071f4"],
 " and ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["STNIntegrate"]], "paclet:SubTropica/ref/STNIntegrate", 
    "SubTropica Package Symbol"},
   "PackageLink",
   BaseStyle->"InlineFunctionSans"]], "InlineFunctionSans",ExpressionUUID->
  "3bafe950-7cfd-4d1a-a5ec-3837a8e1c862"],
 ".  ",
 StyleBox["ginsh", "TI"],
 " is needed only to evaluate hyperlogarithms numerically.  On macOS, install \
most of these via Homebrew; the default Homebrew path for polymake is \
/opt/homebrew/bin/polymake."
}], "GuideText",ExpressionUUID->"423e8fc7-5ad0-4d17-9651-40ddef6eef3c"],

Cell["After configuring, verify the install with", "GuideText",ExpressionUUID->"e5e1ea41-4c82-467d-b6fb-4a58a1f94038"],

Cell[BoxData[
 RowBox[{"STBenchmark", "[", "]"}]], "Input",ExpressionUUID->"2dcaed48-8622-41a9-a59d-6b328a00144a"],

Cell[TextData[{
 "which checks every dependency (see ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["STDependencies"]], "paclet:SubTropica/ref/STDependencies", 
    "SubTropica Package Symbol"},
   "PackageLink",
   BaseStyle->"InlineFunctionSans"]], "InlineFunctionSans",ExpressionUUID->
  "1d6b11de-c697-444d-a8e7-d4a08447709b"],
 ") and runs the curated test suite."
}], "GuideText",ExpressionUUID->"008c5923-263f-45ba-ace6-6acac4059a0e"],

Cell["Mathematica 12.1 or later is required.", "GuideText",ExpressionUUID->"c8a31922-2952-40bf-8e50-44993436e8eb"]
}, Open  ]],


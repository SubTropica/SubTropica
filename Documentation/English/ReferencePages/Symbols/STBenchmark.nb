Notebook[{

Cell[CellGroupData[{
Cell["STBenchmark", "ObjectName",ExpressionUUID->"511c9bf9-c5ef-49a8-8601-fe354abacfa6"],

Cell[BoxData[GridBox[{
   {Cell[TextData[{
     StyleBox["STBenchmark[]", "TI"],
     " \[LineSeparator]runs the full benchmark suite defined in \
mgExamples/mgDiagrams.wl: a dependency check (see STDependencies[]) followed \
by the STIntegrate / STNIntegrate cases exercising every supported input form \
and backend. Cases run sequentially in the main kernel; caches are cleared \
between cases so that one case's state cannot poison the next."
    }], "TableText",ExpressionUUID->"fb824479-741e-41dc-901b-89ff43ac9e24"]},
   {Cell[TextData[{
     StyleBox["STBenchmark[selector]", "TI"],
     " \[LineSeparator]restricts the run to a subset (e.g. \"diagrams\", \
{\"nIntDiagrams\", 1 ;; 3}, or a list of case ids). Options: \"Verify\" -> \
True | False (cross-check nIntDiagrams via STVerify); \"Display\" -> \"Stream\
\" | \"Silent\"; \"Baseline\" -> Automatic | None | _String (path to baseline \
JSON); \"UpdateBaseline\" -> True | False | Automatic (bake current run as \
the new baseline; Automatic writes only when no baseline exists yet); \
\"Report\" -> None | _String (write a Markdown report); \"SkipPackageCheck\" \
-> True | False."
    }], "TableText",ExpressionUUID->"735ed364-4a8e-4f96-a68b-733e6814f772"]}
  },
  GridBoxAlignment->{"Columns" -> {{Left}}},
  GridBoxItemSize->{
   "Columns" -> {{Automatic}}, "Rows" -> {{Automatic}}}]], "Usage",
 CellID->1,ExpressionUUID->"39a555d0-9fe8-4cae-a6cc-6d2e1105aae2"]
}, Open  ]],


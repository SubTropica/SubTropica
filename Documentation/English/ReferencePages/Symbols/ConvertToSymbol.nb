Notebook[{

Cell[CellGroupData[{
Cell["ConvertToSymbol", "ObjectName",ExpressionUUID->"d9757c53-994d-4eb1-91b8-0181babf06fa"],

Cell[BoxData[GridBox[{
   {Cell[TextData[{
     StyleBox["ConvertToSymbol", "TI"],
     " \[LineSeparator]While HyperIntica is the main (analytic) integration \
routine working under the hood of the STIntegrate function, it can also be \
used as a standalone function."
    }], "TableText",ExpressionUUID->"b8257fd5-d6d8-4289-b5f6-f3be80a3d644"]}
  },
  GridBoxAlignment->{"Columns" -> {{Left}}},
  GridBoxItemSize->{
   "Columns" -> {{Automatic}}, "Rows" -> {{Automatic}}}]], "Usage",
 CellID->1,ExpressionUUID->"388fc3af-cb5e-43ea-9cc8-fdac73fdf83b"],

Cell["\<\
While HyperIntica is the main (analytic) integration routine working under \
the hood of the STIntegrate function, it can also be used as a standalone \
function. It evaluates iterated integrals \[Integral]_0^\[Infinity] \
\[Ellipsis] \[Integral]_0^\[Infinity] f\\, dx_1 \[Ellipsis] dx_n in  for \
expressions built from hyperlogarithms, polylogarithms, logarithms, and \
rational functions, returning results in terms of multi-zeta values and \
hyperlogarithms in the original integrand f parameters (if any). The syntax \
is: (see example below)\
\>", "Notes",ExpressionUUID->"52bb3f30-aa0e-494d-b160-78525bf90a6e"],

Cell[BoxData[
 RowBox[{"HyperIntica", "[", 
  RowBox[{"integrand", ",", " ", "variables", ",", " ", 
   RowBox[{"\"\<Monitor\>\"", " ", "->", " ", "False"}]}], "]"}]], "Input",Exp\
ressionUUID->"87d4cb34-44a8-4b42-b00f-d07bc79a6893"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Details", "Section",ExpressionUUID->"62529355-f2fe-4bd9-b6c4-7221dbaede46"],

Cell["Symbol", "Subsection",ExpressionUUID->"e43ff7c3-bef4-4f70-91e4-b9f927f205dd"],

Cell["\<\
ConvertToSymbol[expr] converts an expression containing hyperlogarithms and \
multiple polylogarithms to its ``symbol'' . The available options are: (see \
example below) \"Expand\" -> True (default) factors each symbol letter into \
irreducible polynomials via FactorList, revealing the so-called ``symbol \
alphabet.''\
\>", "Text",ExpressionUUID->"e18fb4d5-80b3-468a-8a45-8b64e8d6fbe7"],

Cell[BoxData[
 RowBox[{"ConvertToSymbol", "[", 
  RowBox[{"expr", ",", " ", 
   RowBox[{"\"\<Expand\>\"", " ", "->", " ", "True"}], ",", "\n", 
   "\t               ", 
   RowBox[{"\"\<DropConstants\>\"", " ", "->", " ", "False"}]}], 
  "]"}]], "Input",ExpressionUUID->"79c8d9d1-e7ce-4aaf-a0c1-026b33fd2cb5"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{"Symbol", " ", "of", " ", 
    RowBox[{"Li", "\\", "textcolor"}], 
    RowBox[{"{", "gray", "}"}], 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"{", "}"}], "_", "2"}], "}"}], 
    RowBox[{"(", "z", ")"}]}], " ", "*)"}], "\n", "\t", 
  RowBox[{
   RowBox[{"ConvertToSymbol", "[", 
    RowBox[{"PolyLog", "[", 
     RowBox[{"2", ",", " ", "z"}], "]"}], "]"}], "  ", 
   RowBox[{"(*", " ", 
    RowBox[{"Out", ":", " ", 
     RowBox[{"Sym", "[", 
      RowBox[{"{", 
       RowBox[{"z", ",", " ", 
        RowBox[{"1", "-", "z"}]}], "}"}], "]"}]}], " ", "*)"}], "\n", "\t", 
   "\n", "\t", 
   RowBox[{"(*", " ", "Symbol", " ", "*)"}], "\n", "\t", 
   RowBox[{"ConvertToSymbol", "[", 
    RowBox[{
     RowBox[{"Log", "[", "x", "]"}], " ", 
     RowBox[{"Log", "[", 
      RowBox[{"1", "-", "x"}], "]"}]}], "]"}], "\n", "\t", 
   RowBox[{"(*", " ", 
    RowBox[{"Out", ":", " ", 
     RowBox[{
      RowBox[{"Sym", "[", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"1", " ", "-", " ", "x"}], ",", " ", "x"}], "}"}], "]"}], 
      " ", "+", " ", 
      RowBox[{"Sym", "[", 
       RowBox[{"{", 
        RowBox[{"x", ",", " ", 
         RowBox[{"1", " ", "-", " ", "x"}]}], "}"}], "]"}]}]}], " ", "*)"}], 
   "\n", "\t", "\n", "\t", 
   RowBox[{"(*", " ", 
    RowBox[{"Without", " ", "factoring", " ", "letters"}], " ", "*)"}], "\n", 
   "\t", 
   RowBox[{"ConvertToSymbol", "[", 
    RowBox[{
     RowBox[{"Hlog", "[", 
      RowBox[{"1", ",", " ", 
       RowBox[{"{", 
        RowBox[{"0", ",", " ", 
         RowBox[{"1", "-", "x"}]}], "}"}]}], "]"}], ",", " ", 
     RowBox[{"\"\<Expand\>\"", " ", "->", " ", "False"}]}], "]"}], "\n", "\t", 
   RowBox[{"(*", " ", 
    RowBox[{"Out", ":", " ", 
     RowBox[{"Sym", "[", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"1", "/", 
         RowBox[{"(", 
          RowBox[{"x", " ", "-", " ", "1"}], ")"}]}], ",", " ", 
        RowBox[{"x", "/", 
         RowBox[{"(", 
          RowBox[{"1", " ", "-", " ", "x"}], ")"}]}]}], "}"}], "]"}]}], " ", 
    "*)"}]}]}]], "Input",ExpressionUUID->"daf74fde-ee40-4e98-9a55-\
042e32f73407"]
}, Open  ]],


Notebook[{

Cell[CellGroupData[{
Cell["ConvertToSymbol", "ObjectName",ExpressionUUID->"a7687dd8-654b-4436-9df6-dc1dd9730579"],

Cell[BoxData[GridBox[{
   {Cell[TextData[{
     StyleBox["ConvertToSymbol", "TI"],
     " \[LineSeparator]While HyperIntica is the main (analytic) integration \
routine working under the hood of the STIntegrate function, it can also be \
used as a standalone function."
    }], "TableText",ExpressionUUID->"c6ad26c2-ba6a-45f1-bf80-af75a96a9c00"]}
  },
  GridBoxAlignment->{"Columns" -> {{Left}}},
  GridBoxItemSize->{
   "Columns" -> {{Automatic}}, "Rows" -> {{Automatic}}}]], "Usage",
 CellID->1,ExpressionUUID->"f7b374ab-7653-493e-8b2c-f992b92f59c6"],

Cell["\<\
While HyperIntica is the main (analytic) integration routine working under \
the hood of the STIntegrate function, it can also be used as a standalone \
function. It evaluates iterated integrals \[Integral]_0^\[Infinity] \
\[Ellipsis] \[Integral]_0^\[Infinity] f\\, dx_1 \[Ellipsis] dx_n in  for \
expressions built from hyperlogarithms, polylogarithms, logarithms, and \
rational functions, returning results in terms of multi-zeta values and \
hyperlogarithms in the original integrand f parameters (if any). The syntax \
is: (see example below)\
\>", "Notes",ExpressionUUID->"e7fc9eb5-a66c-448f-aadb-e7338399037b"],

Cell[BoxData[
 RowBox[{"HyperIntica", "[", 
  RowBox[{"integrand", ",", " ", "variables", ",", " ", 
   RowBox[{"\"\<Monitor\>\"", " ", "->", " ", "False"}]}], "]"}]], "Input",Exp\
ressionUUID->"4df4a791-1376-45ef-9960-d938a67221d8"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Details", "Section",ExpressionUUID->"fc35549f-22f0-481c-b60f-6c601ce0df4b"],

Cell["Symbol", "Subsection",ExpressionUUID->"56a4fb64-61e9-4bd6-9c1e-e78d217557f0"],

Cell["\<\
ConvertToSymbol[expr] converts an expression containing hyperlogarithms and \
multiple polylogarithms to its ``symbol'' . The available options are: (see \
example below) \"Expand\" -> True (default) factors each symbol letter into \
irreducible polynomials via FactorList, revealing the so-called ``symbol \
alphabet.''\
\>", "Text",ExpressionUUID->"89b85c13-7f13-4581-b0c8-bd791393e68e"],

Cell[BoxData[
 RowBox[{"ConvertToSymbol", "[", 
  RowBox[{"expr", ",", " ", 
   RowBox[{"\"\<Expand\>\"", " ", "->", " ", "True"}], ",", "\n", 
   "\t               ", 
   RowBox[{"\"\<DropConstants\>\"", " ", "->", " ", "False"}]}], 
  "]"}]], "Input",ExpressionUUID->"9c19cc8b-3c38-48f2-907f-5e09788babb8"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{"Symbol", " ", "of", " ", 
    RowBox[{"Li", "\\", "textcolor"}], 
    RowBox[{"{", "gray", "}"}], 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"{", "}"}], "_", "2"}], "}"}], 
    RowBox[{"(", "z", ")"}]}], " ", "*)"}], "\n", "\t", 
  RowBox[{
   RowBox[{"ConvertToSymbol", "[", 
    RowBox[{"PolyLog", "[", 
     RowBox[{"2", ",", " ", "z"}], "]"}], "]"}], "  ", 
   RowBox[{"(*", " ", 
    RowBox[{"Out", ":", " ", 
     RowBox[{"Sym", "[", 
      RowBox[{"{", 
       RowBox[{"z", ",", " ", 
        RowBox[{"1", "-", "z"}]}], "}"}], "]"}]}], " ", "*)"}], "\n", "\t", 
   "\n", "\t", 
   RowBox[{"(*", " ", "Symbol", " ", "*)"}], "\n", "\t", 
   RowBox[{"ConvertToSymbol", "[", 
    RowBox[{
     RowBox[{"Log", "[", "x", "]"}], " ", 
     RowBox[{"Log", "[", 
      RowBox[{"1", "-", "x"}], "]"}]}], "]"}], "\n", "\t", 
   RowBox[{"(*", " ", 
    RowBox[{"Out", ":", " ", 
     RowBox[{
      RowBox[{"Sym", "[", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"1", " ", "-", " ", "x"}], ",", " ", "x"}], "}"}], "]"}], 
      " ", "+", " ", 
      RowBox[{"Sym", "[", 
       RowBox[{"{", 
        RowBox[{"x", ",", " ", 
         RowBox[{"1", " ", "-", " ", "x"}]}], "}"}], "]"}]}]}], " ", "*)"}], 
   "\n", "\t", "\n", "\t", 
   RowBox[{"(*", " ", 
    RowBox[{"Without", " ", "factoring", " ", "letters"}], " ", "*)"}], "\n", 
   "\t", 
   RowBox[{"ConvertToSymbol", "[", 
    RowBox[{
     RowBox[{"Hlog", "[", 
      RowBox[{"1", ",", " ", 
       RowBox[{"{", 
        RowBox[{"0", ",", " ", 
         RowBox[{"1", "-", "x"}]}], "}"}]}], "]"}], ",", " ", 
     RowBox[{"\"\<Expand\>\"", " ", "->", " ", "False"}]}], "]"}], "\n", "\t", 
   RowBox[{"(*", " ", 
    RowBox[{"Out", ":", " ", 
     RowBox[{"Sym", "[", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"1", "/", 
         RowBox[{"(", 
          RowBox[{"x", " ", "-", " ", "1"}], ")"}]}], ",", " ", 
        RowBox[{"x", "/", 
         RowBox[{"(", 
          RowBox[{"1", " ", "-", " ", "x"}], ")"}]}]}], "}"}], "]"}]}], " ", 
    "*)"}]}]}]], "Input",ExpressionUUID->"b011150c-b2c1-4cb7-8aba-\
0b687ae25a9c"]
}, Open  ]],


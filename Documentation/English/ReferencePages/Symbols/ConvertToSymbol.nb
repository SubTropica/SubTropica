Notebook[{

Cell[CellGroupData[{
Cell["ConvertToSymbol", "ObjectName",ExpressionUUID->"607c384d-75af-4402-b4ff-8b7bc956e7d3"],

Cell[BoxData[GridBox[{
   {Cell[TextData[{
     StyleBox["ConvertToSymbol", "TI"],
     " \[LineSeparator]While HyperIntica is the main (analytic) integration \
routine working under the hood of the STIntegrate function, it can also be \
used as a standalone function."
    }], "TableText",ExpressionUUID->"b4358159-2462-4121-b66f-ae7083922c22"]}
  },
  GridBoxAlignment->{"Columns" -> {{Left}}},
  GridBoxItemSize->{
   "Columns" -> {{Automatic}}, "Rows" -> {{Automatic}}}]], "Usage",
 CellID->1,ExpressionUUID->"b8e0a268-263a-46bd-966a-6b3815482470"],

Cell["\<\
While HyperIntica is the main (analytic) integration routine working under \
the hood of the STIntegrate function, it can also be used as a standalone \
function. It evaluates iterated integrals \[Integral]_0^\[Infinity] \
\[Ellipsis] \[Integral]_0^\[Infinity] f\\, dx_1 \[Ellipsis] dx_n in  for \
expressions built from hyperlogarithms, polylogarithms, logarithms, and \
rational functions, returning results in terms of multi-zeta values and \
hyperlogarithms in the original integrand f parameters (if any). The syntax \
is: (see example below)\
\>", "Notes",ExpressionUUID->"0f795322-94ed-49a7-836b-1ed70830c655"],

Cell[BoxData[
 RowBox[{"HyperIntica", "[", 
  RowBox[{"integrand", ",", " ", "variables", ",", " ", 
   RowBox[{"\"\<Monitor\>\"", " ", "->", " ", "False"}]}], "]"}]], "Input",Exp\
ressionUUID->"ffbcf362-6361-4aa0-a101-aee54579a6b7"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Details", "Section",ExpressionUUID->"6f6aab2d-3c64-4da4-9d42-f03f61b76769"],

Cell["Symbol", "Subsection",ExpressionUUID->"0107c0e7-f132-4287-9431-662084f52ecc"],

Cell["\<\
ConvertToSymbol[expr] converts an expression containing hyperlogarithms and \
multiple polylogarithms to its ``symbol'' . The available options are: (see \
example below) \"Expand\" -> True (default) factors each symbol letter into \
irreducible polynomials via FactorList, revealing the so-called ``symbol \
alphabet.''\
\>", "Text",ExpressionUUID->"cd9271a5-36bd-4691-94c4-5a23bd3064e8"],

Cell[BoxData[
 RowBox[{"ConvertToSymbol", "[", 
  RowBox[{"expr", ",", " ", 
   RowBox[{"\"\<Expand\>\"", " ", "->", " ", "True"}], ",", "\n", 
   "\t               ", 
   RowBox[{"\"\<DropConstants\>\"", " ", "->", " ", "False"}]}], 
  "]"}]], "Input",ExpressionUUID->"92c572a0-b3f0-4340-87d5-80d4f678f85e"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{"Symbol", " ", "of", " ", 
    RowBox[{"Li", "\\", "textcolor"}], 
    RowBox[{"{", "gray", "}"}], 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"{", "}"}], "_", "2"}], "}"}], 
    RowBox[{"(", "z", ")"}]}], " ", "*)"}], "\n", "\t", 
  RowBox[{
   RowBox[{"ConvertToSymbol", "[", 
    RowBox[{"PolyLog", "[", 
     RowBox[{"2", ",", " ", "z"}], "]"}], "]"}], "  ", 
   RowBox[{"(*", " ", 
    RowBox[{"Out", ":", " ", 
     RowBox[{"Sym", "[", 
      RowBox[{"{", 
       RowBox[{"z", ",", " ", 
        RowBox[{"1", "-", "z"}]}], "}"}], "]"}]}], " ", "*)"}], "\n", "\t", 
   "\n", "\t", 
   RowBox[{"(*", " ", "Symbol", " ", "*)"}], "\n", "\t", 
   RowBox[{"ConvertToSymbol", "[", 
    RowBox[{
     RowBox[{"Log", "[", "x", "]"}], " ", 
     RowBox[{"Log", "[", 
      RowBox[{"1", "-", "x"}], "]"}]}], "]"}], "\n", "\t", 
   RowBox[{"(*", " ", 
    RowBox[{"Out", ":", " ", 
     RowBox[{
      RowBox[{"Sym", "[", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"1", " ", "-", " ", "x"}], ",", " ", "x"}], "}"}], "]"}], 
      " ", "+", " ", 
      RowBox[{"Sym", "[", 
       RowBox[{"{", 
        RowBox[{"x", ",", " ", 
         RowBox[{"1", " ", "-", " ", "x"}]}], "}"}], "]"}]}]}], " ", "*)"}], 
   "\n", "\t", "\n", "\t", 
   RowBox[{"(*", " ", 
    RowBox[{"Without", " ", "factoring", " ", "letters"}], " ", "*)"}], "\n", 
   "\t", 
   RowBox[{"ConvertToSymbol", "[", 
    RowBox[{
     RowBox[{"Hlog", "[", 
      RowBox[{"1", ",", " ", 
       RowBox[{"{", 
        RowBox[{"0", ",", " ", 
         RowBox[{"1", "-", "x"}]}], "}"}]}], "]"}], ",", " ", 
     RowBox[{"\"\<Expand\>\"", " ", "->", " ", "False"}]}], "]"}], "\n", "\t", 
   RowBox[{"(*", " ", 
    RowBox[{"Out", ":", " ", 
     RowBox[{"Sym", "[", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"1", "/", 
         RowBox[{"(", 
          RowBox[{"x", " ", "-", " ", "1"}], ")"}]}], ",", " ", 
        RowBox[{"x", "/", 
         RowBox[{"(", 
          RowBox[{"1", " ", "-", " ", "x"}], ")"}]}]}], "}"}], "]"}]}], " ", 
    "*)"}]}]}]], "Input",ExpressionUUID->"d558db2c-a887-44bb-b7bd-\
ae7571e348a0"]
}, Open  ]],


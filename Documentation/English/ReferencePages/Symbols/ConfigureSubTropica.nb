Notebook[{

Cell[CellGroupData[{
Cell["ConfigureSubTropica", "ObjectName",ExpressionUUID->"b2657316-452b-42e7-b355-f330a7d0639a"],

Cell[BoxData[GridBox[{
   {Cell[TextData[{
     StyleBox["ConfigureSubTropica[opt -> val, ...]", "TI"],
     " \[LineSeparator]sets external-tool paths (PolymakePath, GinshPath, \
MaplePath, HyperIntPath, PythonPath, FiniteFlowPath, SPQRPath, FIESTAPath, \
AMFlowPath, LiteRedPath, LiteIBPPath, FIREPath, FeyntropPath, \
PolymakeConcurrencyFraction). The configuration is auto-persisted to \
$STConfigFile and reapplied on the next Get[\"SubTropica`\"], so you only \
need to call this once per machine."
    }], "TableText",ExpressionUUID->"bb24d9e0-abea-4f8f-a601-a61fcc7db4cc"]}
  },
  GridBoxAlignment->{"Columns" -> {{Left}}},
  GridBoxItemSize->{
   "Columns" -> {{Automatic}}, "Rows" -> {{Automatic}}}]], "Usage",
 CellID->1,ExpressionUUID->"69a04836-8a0f-4ea5-bac5-a9e9252395da"]
}, Open  ]],


Notebook[{

Cell[CellGroupData[{
Cell["ConfigureSubTropica", "ObjectName",ExpressionUUID->"a1cc915b-0d91-4fa2-b347-f965c3193ef7"],

Cell[BoxData[GridBox[{
   {Cell[TextData[{
     StyleBox["ConfigureSubTropica[opt -> val, ...]", "TI"],
     " \[LineSeparator]sets external-tool paths (PolymakePath, GinshPath, \
MaplePath, HyperIntPath, HyperFlintPath, PythonPath, FiniteFlowPath, \
SPQRPath, FIESTAPath, AMFlowPath, LiteRedPath, LiteIBPPath, FIREPath, \
FeyntropPath, PolymakeConcurrencyFraction). The configuration is \
auto-persisted to $STConfigFile and reapplied on the next \
Get[\"SubTropica`\"], so you only need to call this once per machine."
    }], "TableText",ExpressionUUID->"57bf5ae2-af2f-4585-b9e1-f7e78590418e"]}
  },
  GridBoxAlignment->{"Columns" -> {{Left}}},
  GridBoxItemSize->{
   "Columns" -> {{Automatic}}, "Rows" -> {{Automatic}}}]], "Usage",
 CellID->1,ExpressionUUID->"0bf5884f-b318-40d4-b3f1-232f53072b13"]
}, Open  ]],


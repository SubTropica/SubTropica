Notebook[{

Cell[CellGroupData[{
Cell["HyperSeries", "ObjectName",ExpressionUUID->"db7dc50a-3e62-4014-a80a-ae1002bc3866"],

Cell[BoxData[GridBox[{
   {Cell[TextData[{
     StyleBox["HyperSeries", "TI"],
     " \[LineSeparator]While HyperIntica is the main (analytic) integration \
routine working under the hood of the STIntegrate function, it can also be \
used as a standalone function."
    }], "TableText",ExpressionUUID->"a44edc0b-b956-4c48-acbe-b66e750eb91f"]}
  },
  GridBoxAlignment->{"Columns" -> {{Left}}},
  GridBoxItemSize->{
   "Columns" -> {{Automatic}}, "Rows" -> {{Automatic}}}]], "Usage",
 CellID->1,ExpressionUUID->"1a8b9ab1-2a86-4ebf-a7af-08e4d5572913"],

Cell["\<\
While HyperIntica is the main (analytic) integration routine working under \
the hood of the STIntegrate function, it can also be used as a standalone \
function. It evaluates iterated integrals \[Integral]_0^\[Infinity] \
\[Ellipsis] \[Integral]_0^\[Infinity] f\\, dx_1 \[Ellipsis] dx_n in  for \
expressions built from hyperlogarithms, polylogarithms, logarithms, and \
rational functions, returning results in terms of multi-zeta values and \
hyperlogarithms in the original integrand f parameters (if any). The syntax \
is: (see example below)\
\>", "Notes",ExpressionUUID->"e1fe06d7-9558-4936-b4c1-bee8d1f4a021"],

Cell[BoxData[
 RowBox[{"HyperIntica", "[", 
  RowBox[{"integrand", ",", " ", "variables", ",", " ", 
   RowBox[{"\"\<Monitor\>\"", " ", "->", " ", "False"}]}], "]"}]], "Input",Exp\
ressionUUID->"a0bdaef1-4b10-4a5a-881b-9dba2fc569d4"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Details", "Section",ExpressionUUID->"4de07bfd-b83f-45c8-a4fb-9561a69b83b3"],

Cell["Series", "Subsection",ExpressionUUID->"8d6747e2-37f6-4c77-ac5f-f4d537f8520e"],

Cell["\<\
HyperSeries[expr, {var, point, order}] expands expr around var = point \
through O((var-point)^{order}), handling Hlog and Mpl when their arguments \
depend on the expansion variable (unlike the built-in Series). Some examples \
are: (see example below)\
\>", "Text",ExpressionUUID->"f00e8629-6324-4a04-b87e-6664c5b91fcf"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{"Expand", " ", 
     RowBox[{"Li", "\\", "textcolor"}], 
     RowBox[{"{", "gray", "}"}], 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"{", "}"}], "_", "2"}], "}"}], 
     RowBox[{"(", "z", ")"}], " ", "around", " ", "z"}], " ", "=", " ", "0"}],
    " ", "*)"}], "\n", "\t", 
  RowBox[{
   RowBox[{"HyperSeries", "[", 
    RowBox[{
     RowBox[{"Mpl", "[", 
      RowBox[{
       RowBox[{"{", "2", "}"}], ",", " ", 
       RowBox[{"{", "z", "}"}]}], "]"}], ",", " ", 
     RowBox[{"{", 
      RowBox[{"z", ",", " ", "0", ",", " ", "5"}], "}"}]}], "]"}], "\n", "\t", 
   RowBox[{"(*", " ", 
    RowBox[{"Out", ":", " ", 
     RowBox[{"z", " ", "+", " ", 
      RowBox[{
       RowBox[{"z", "^", "2"}], "/", "4"}], " ", "+", " ", 
      RowBox[{
       RowBox[{"z", "^", "3"}], "/", "9"}], " ", "+", " ", 
      RowBox[{
       RowBox[{"z", "^", "4"}], "/", "16"}], " ", "+", " ", 
      RowBox[{
       RowBox[{"z", "^", "5"}], "/", "25"}]}]}], " ", "*)"}], "\n", "\t", 
   "\n", "\t", 
   RowBox[{"(*", " ", 
    RowBox[{"Expand", " ", "with", " ", "parametric", " ", "dependence"}], 
    " ", "*)"}], "\n", "\t", 
   RowBox[{"HyperSeries", "[", 
    RowBox[{
     RowBox[{"Mpl", "[", 
      RowBox[{
       RowBox[{"{", "2", "}"}], ",", " ", 
       RowBox[{"{", 
        RowBox[{"1", " ", "-", " ", 
         RowBox[{"x", "/", "u"}]}], "}"}]}], "]"}], ",", " ", 
     RowBox[{"{", 
      RowBox[{"x", ",", " ", "0", ",", " ", "3"}], "}"}]}], "]"}], "\n", "\t", 
   RowBox[{"(*", " ", 
    RowBox[{"Out", ":", " ", 
     RowBox[{
      RowBox[{
       RowBox[{"Pi", "^", "2"}], "/", "6"}], " ", "+", " ", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{"x", "*", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{"-", "1"}], " ", "+", " ", 
           RowBox[{"Log", "[", 
            RowBox[{"x", "/", "u"}], "]"}]}], ")"}]}], ")"}], "/", "u"}], " ",
       "+", " ", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{
         RowBox[{"x", "^", "2"}], "*", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{"-", "1"}], " ", "+", " ", 
           RowBox[{"2", "*", 
            RowBox[{"Log", "[", 
             RowBox[{"x", "/", "u"}], "]"}]}]}], ")"}]}], ")"}], "/", 
       RowBox[{"(", 
        RowBox[{"4", "*", 
         RowBox[{"u", "^", "2"}]}], ")"}]}], " ", "+", " ", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{
         RowBox[{"x", "^", "3"}], "*", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{"-", "1"}], " ", "+", " ", 
           RowBox[{"3", "*", 
            RowBox[{"Log", "[", 
             RowBox[{"x", "/", "u"}], "]"}]}]}], ")"}]}], ")"}], "/", 
       RowBox[{"(", 
        RowBox[{"9", "*", 
         RowBox[{"u", "^", "3"}]}], ")"}]}]}]}], " ", "*)"}], "\n", "\t", 
   "\n", "\t", 
   RowBox[{"(*", " ", 
    RowBox[{
    "Expand", " ", "Hlog", " ", "with", " ", "argument", " ", "approaching", " ",
      "0"}], " ", "*)"}], "\n", "\t", 
   RowBox[{"HyperSeries", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"Hlog", "[", 
       RowBox[{"z", ",", " ", 
        RowBox[{"{", 
         RowBox[{"0", ",", " ", "1"}], "}"}]}], "]"}], "/", "z"}], ",", " ", 
     RowBox[{"{", 
      RowBox[{"z", ",", " ", "0", ",", " ", "4"}], "}"}]}], "]"}], "\n", "\t", 
   RowBox[{"(*", " ", 
    RowBox[{"Out", ":", " ", 
     RowBox[{
      RowBox[{"-", "1"}], " ", "-", " ", 
      RowBox[{"z", "/", "4"}], " ", "-", " ", 
      RowBox[{
       RowBox[{"z", "^", "2"}], "/", "9"}], " ", "-", " ", 
      RowBox[{
       RowBox[{"z", "^", "3"}], "/", "16"}]}]}], " ", "*)"}]}]}]], "Input",Exp\
ressionUUID->"15572164-83ff-4e4a-b7a2-f9aa270acb70"]
}, Open  ]],


Notebook[{

Cell[CellGroupData[{
Cell["HyperSeries", "ObjectName",ExpressionUUID->"6816ec64-3951-4f38-b63f-e9e02aa65bd6"],

Cell[BoxData[GridBox[{
   {Cell[TextData[{
     StyleBox["HyperSeries", "TI"],
     " \[LineSeparator]While HyperIntica is the main (analytic) integration \
routine working under the hood of the STIntegrate function, it can also be \
used as a standalone function."
    }], "TableText",ExpressionUUID->"0093e1e2-3a2e-4fe4-bfd8-57f83b0b62a1"]}
  },
  GridBoxAlignment->{"Columns" -> {{Left}}},
  GridBoxItemSize->{
   "Columns" -> {{Automatic}}, "Rows" -> {{Automatic}}}]], "Usage",
 CellID->1,ExpressionUUID->"836185b3-1d60-4fa1-bfd9-11281e6805b2"],

Cell["\<\
While HyperIntica is the main (analytic) integration routine working under \
the hood of the STIntegrate function, it can also be used as a standalone \
function. It evaluates iterated integrals \[Integral]_0^\[Infinity] \
\[Ellipsis] \[Integral]_0^\[Infinity] f\\, dx_1 \[Ellipsis] dx_n in  for \
expressions built from hyperlogarithms, polylogarithms, logarithms, and \
rational functions, returning results in terms of multi-zeta values and \
hyperlogarithms in the original integrand f parameters (if any). The syntax \
is: (see example below)\
\>", "Notes",ExpressionUUID->"1776e951-edbf-4a93-ac0b-7b2da6d608f4"],

Cell[BoxData[
 RowBox[{"HyperIntica", "[", 
  RowBox[{"integrand", ",", " ", "variables", ",", " ", 
   RowBox[{"\"\<Monitor\>\"", " ", "->", " ", "False"}]}], "]"}]], "Input",Exp\
ressionUUID->"26e48890-4352-4406-9231-c0b2b75b93df"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Details", "Section",ExpressionUUID->"8ddd30d5-8813-4a0e-87bc-9c65080e857c"],

Cell["Series", "Subsection",ExpressionUUID->"e9c29b7c-d285-4363-acbc-bf4771b58d7a"],

Cell["\<\
HyperSeries[expr, {var, point, order}] expands expr around var = point \
through O((var-point)^{order}), handling Hlog and Mpl when their arguments \
depend on the expansion variable (unlike the built-in Series). Some examples \
are: (see example below)\
\>", "Text",ExpressionUUID->"ae92ef12-e5fb-4b5c-aed9-fe3b464ac4ac"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{"Expand", " ", 
     RowBox[{"Li", "\\", "textcolor"}], 
     RowBox[{"{", "gray", "}"}], 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"{", "}"}], "_", "2"}], "}"}], 
     RowBox[{"(", "z", ")"}], " ", "around", " ", "z"}], " ", "=", " ", "0"}],
    " ", "*)"}], "\n", "\t", 
  RowBox[{
   RowBox[{"HyperSeries", "[", 
    RowBox[{
     RowBox[{"Mpl", "[", 
      RowBox[{
       RowBox[{"{", "2", "}"}], ",", " ", 
       RowBox[{"{", "z", "}"}]}], "]"}], ",", " ", 
     RowBox[{"{", 
      RowBox[{"z", ",", " ", "0", ",", " ", "5"}], "}"}]}], "]"}], "\n", "\t", 
   RowBox[{"(*", " ", 
    RowBox[{"Out", ":", " ", 
     RowBox[{"z", " ", "+", " ", 
      RowBox[{
       RowBox[{"z", "^", "2"}], "/", "4"}], " ", "+", " ", 
      RowBox[{
       RowBox[{"z", "^", "3"}], "/", "9"}], " ", "+", " ", 
      RowBox[{
       RowBox[{"z", "^", "4"}], "/", "16"}], " ", "+", " ", 
      RowBox[{
       RowBox[{"z", "^", "5"}], "/", "25"}]}]}], " ", "*)"}], "\n", "\t", 
   "\n", "\t", 
   RowBox[{"(*", " ", 
    RowBox[{"Expand", " ", "with", " ", "parametric", " ", "dependence"}], 
    " ", "*)"}], "\n", "\t", 
   RowBox[{"HyperSeries", "[", 
    RowBox[{
     RowBox[{"Mpl", "[", 
      RowBox[{
       RowBox[{"{", "2", "}"}], ",", " ", 
       RowBox[{"{", 
        RowBox[{"1", " ", "-", " ", 
         RowBox[{"x", "/", "u"}]}], "}"}]}], "]"}], ",", " ", 
     RowBox[{"{", 
      RowBox[{"x", ",", " ", "0", ",", " ", "3"}], "}"}]}], "]"}], "\n", "\t", 
   RowBox[{"(*", " ", 
    RowBox[{"Out", ":", " ", 
     RowBox[{
      RowBox[{
       RowBox[{"Pi", "^", "2"}], "/", "6"}], " ", "+", " ", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{"x", "*", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{"-", "1"}], " ", "+", " ", 
           RowBox[{"Log", "[", 
            RowBox[{"x", "/", "u"}], "]"}]}], ")"}]}], ")"}], "/", "u"}], " ",
       "+", " ", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{
         RowBox[{"x", "^", "2"}], "*", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{"-", "1"}], " ", "+", " ", 
           RowBox[{"2", "*", 
            RowBox[{"Log", "[", 
             RowBox[{"x", "/", "u"}], "]"}]}]}], ")"}]}], ")"}], "/", 
       RowBox[{"(", 
        RowBox[{"4", "*", 
         RowBox[{"u", "^", "2"}]}], ")"}]}], " ", "+", " ", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{
         RowBox[{"x", "^", "3"}], "*", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{"-", "1"}], " ", "+", " ", 
           RowBox[{"3", "*", 
            RowBox[{"Log", "[", 
             RowBox[{"x", "/", "u"}], "]"}]}]}], ")"}]}], ")"}], "/", 
       RowBox[{"(", 
        RowBox[{"9", "*", 
         RowBox[{"u", "^", "3"}]}], ")"}]}]}]}], " ", "*)"}], "\n", "\t", 
   "\n", "\t", 
   RowBox[{"(*", " ", 
    RowBox[{
    "Expand", " ", "Hlog", " ", "with", " ", "argument", " ", "approaching", " ",
      "0"}], " ", "*)"}], "\n", "\t", 
   RowBox[{"HyperSeries", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"Hlog", "[", 
       RowBox[{"z", ",", " ", 
        RowBox[{"{", 
         RowBox[{"0", ",", " ", "1"}], "}"}]}], "]"}], "/", "z"}], ",", " ", 
     RowBox[{"{", 
      RowBox[{"z", ",", " ", "0", ",", " ", "4"}], "}"}]}], "]"}], "\n", "\t", 
   RowBox[{"(*", " ", 
    RowBox[{"Out", ":", " ", 
     RowBox[{
      RowBox[{"-", "1"}], " ", "-", " ", 
      RowBox[{"z", "/", "4"}], " ", "-", " ", 
      RowBox[{
       RowBox[{"z", "^", "2"}], "/", "9"}], " ", "-", " ", 
      RowBox[{
       RowBox[{"z", "^", "3"}], "/", "16"}]}]}], " ", "*)"}]}]}]], "Input",Exp\
ressionUUID->"667044ff-4670-4bc1-bc6c-4a9a8e7719c1"]
}, Open  ]],


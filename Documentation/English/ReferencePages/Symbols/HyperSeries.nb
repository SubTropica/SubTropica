Notebook[{

Cell[CellGroupData[{
Cell["HyperSeries", "ObjectName",ExpressionUUID->"a055f80e-0d00-46de-906b-ab4c672f01f5"],

Cell[BoxData[GridBox[{
   {Cell[TextData[{
     StyleBox["HyperSeries", "TI"],
     " \[LineSeparator]While HyperIntica is the main (analytic) integration \
routine working under the hood of the STIntegrate function, it can also be \
used as a standalone function."
    }], "TableText",ExpressionUUID->"7401d2d1-b9e9-425c-a702-549ec5c8dbe0"]}
  },
  GridBoxAlignment->{"Columns" -> {{Left}}},
  GridBoxItemSize->{
   "Columns" -> {{Automatic}}, "Rows" -> {{Automatic}}}]], "Usage",
 CellID->1,ExpressionUUID->"01199c2a-af03-4471-996b-54d8986c3030"],

Cell["\<\
While HyperIntica is the main (analytic) integration routine working under \
the hood of the STIntegrate function, it can also be used as a standalone \
function. It evaluates iterated integrals \[Integral]_0^\[Infinity] \
\[Ellipsis] \[Integral]_0^\[Infinity] f\\, dx_1 \[Ellipsis] dx_n in  for \
expressions built from hyperlogarithms, polylogarithms, logarithms, and \
rational functions, returning results in terms of multi-zeta values and \
hyperlogarithms in the original integrand f parameters (if any). The syntax \
is: (see example below)\
\>", "Notes",ExpressionUUID->"413ba265-2ae9-42c5-b78c-4a404b6c78ce"],

Cell[BoxData[
 RowBox[{"HyperIntica", "[", 
  RowBox[{"integrand", ",", " ", "variables", ",", " ", 
   RowBox[{"\"\<Monitor\>\"", " ", "->", " ", "False"}]}], "]"}]], "Input",Exp\
ressionUUID->"3b3a82b9-e2fe-4ae3-90f5-c5d657329b0c"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Details", "Section",ExpressionUUID->"316f3c75-42a6-4adb-bb68-0b002ec17874"],

Cell["Series", "Subsection",ExpressionUUID->"caf989ca-94a7-4650-83af-7f8fbc1968b1"],

Cell["\<\
HyperSeries[expr, {var, point, order}] expands expr around var = point \
through O((var-point)^{order}), handling Hlog and Mpl when their arguments \
depend on the expansion variable (unlike the built-in Series). Some examples \
are: (see example below)\
\>", "Text",ExpressionUUID->"ec0ab58c-3f19-490e-b28e-538e0a80f09f"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{"Expand", " ", 
     RowBox[{"Li", "\\", "textcolor"}], 
     RowBox[{"{", "gray", "}"}], 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"{", "}"}], "_", "2"}], "}"}], 
     RowBox[{"(", "z", ")"}], " ", "around", " ", "z"}], " ", "=", " ", "0"}],
    " ", "*)"}], "\n", "\t", 
  RowBox[{
   RowBox[{"HyperSeries", "[", 
    RowBox[{
     RowBox[{"Mpl", "[", 
      RowBox[{
       RowBox[{"{", "2", "}"}], ",", " ", 
       RowBox[{"{", "z", "}"}]}], "]"}], ",", " ", 
     RowBox[{"{", 
      RowBox[{"z", ",", " ", "0", ",", " ", "5"}], "}"}]}], "]"}], "\n", "\t", 
   RowBox[{"(*", " ", 
    RowBox[{"Out", ":", " ", 
     RowBox[{"z", " ", "+", " ", 
      RowBox[{
       RowBox[{"z", "^", "2"}], "/", "4"}], " ", "+", " ", 
      RowBox[{
       RowBox[{"z", "^", "3"}], "/", "9"}], " ", "+", " ", 
      RowBox[{
       RowBox[{"z", "^", "4"}], "/", "16"}], " ", "+", " ", 
      RowBox[{
       RowBox[{"z", "^", "5"}], "/", "25"}]}]}], " ", "*)"}], "\n", "\t", 
   "\n", "\t", 
   RowBox[{"(*", " ", 
    RowBox[{"Expand", " ", "with", " ", "parametric", " ", "dependence"}], 
    " ", "*)"}], "\n", "\t", 
   RowBox[{"HyperSeries", "[", 
    RowBox[{
     RowBox[{"Mpl", "[", 
      RowBox[{
       RowBox[{"{", "2", "}"}], ",", " ", 
       RowBox[{"{", 
        RowBox[{"1", " ", "-", " ", 
         RowBox[{"x", "/", "u"}]}], "}"}]}], "]"}], ",", " ", 
     RowBox[{"{", 
      RowBox[{"x", ",", " ", "0", ",", " ", "3"}], "}"}]}], "]"}], "\n", "\t", 
   RowBox[{"(*", " ", 
    RowBox[{"Out", ":", " ", 
     RowBox[{
      RowBox[{
       RowBox[{"Pi", "^", "2"}], "/", "6"}], " ", "+", " ", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{"x", "*", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{"-", "1"}], " ", "+", " ", 
           RowBox[{"Log", "[", 
            RowBox[{"x", "/", "u"}], "]"}]}], ")"}]}], ")"}], "/", "u"}], " ",
       "+", " ", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{
         RowBox[{"x", "^", "2"}], "*", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{"-", "1"}], " ", "+", " ", 
           RowBox[{"2", "*", 
            RowBox[{"Log", "[", 
             RowBox[{"x", "/", "u"}], "]"}]}]}], ")"}]}], ")"}], "/", 
       RowBox[{"(", 
        RowBox[{"4", "*", 
         RowBox[{"u", "^", "2"}]}], ")"}]}], " ", "+", " ", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{
         RowBox[{"x", "^", "3"}], "*", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{"-", "1"}], " ", "+", " ", 
           RowBox[{"3", "*", 
            RowBox[{"Log", "[", 
             RowBox[{"x", "/", "u"}], "]"}]}]}], ")"}]}], ")"}], "/", 
       RowBox[{"(", 
        RowBox[{"9", "*", 
         RowBox[{"u", "^", "3"}]}], ")"}]}]}]}], " ", "*)"}], "\n", "\t", 
   "\n", "\t", 
   RowBox[{"(*", " ", 
    RowBox[{
    "Expand", " ", "Hlog", " ", "with", " ", "argument", " ", "approaching", " ",
      "0"}], " ", "*)"}], "\n", "\t", 
   RowBox[{"HyperSeries", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"Hlog", "[", 
       RowBox[{"z", ",", " ", 
        RowBox[{"{", 
         RowBox[{"0", ",", " ", "1"}], "}"}]}], "]"}], "/", "z"}], ",", " ", 
     RowBox[{"{", 
      RowBox[{"z", ",", " ", "0", ",", " ", "4"}], "}"}]}], "]"}], "\n", "\t", 
   RowBox[{"(*", " ", 
    RowBox[{"Out", ":", " ", 
     RowBox[{
      RowBox[{"-", "1"}], " ", "-", " ", 
      RowBox[{"z", "/", "4"}], " ", "-", " ", 
      RowBox[{
       RowBox[{"z", "^", "2"}], "/", "9"}], " ", "-", " ", 
      RowBox[{
       RowBox[{"z", "^", "3"}], "/", "16"}]}]}], " ", "*)"}]}]}]], "Input",Exp\
ressionUUID->"1b7a9a33-9c04-4437-9539-f3e7d272c9d2"]
}, Open  ]],


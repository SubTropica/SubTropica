Notebook[{

Cell[CellGroupData[{
Cell["CleanZeroInf", "ObjectName",ExpressionUUID->"d492b3f3-597b-4145-a7bf-0fd67b6bf796"],

Cell[BoxData[GridBox[{
   {Cell[TextData[{
     StyleBox["CleanZeroInf", "TI"],
     " \[LineSeparator]While HyperIntica is the main (analytic) integration \
routine working under the hood of the STIntegrate function, it can also be \
used as a standalone function."
    }], "TableText",ExpressionUUID->"b55da1e8-3925-4a28-8080-a1aa7de8a62c"]}
  },
  GridBoxAlignment->{"Columns" -> {{Left}}},
  GridBoxItemSize->{
   "Columns" -> {{Automatic}}, "Rows" -> {{Automatic}}}]], "Usage",
 CellID->1,ExpressionUUID->"1e5c449f-71b1-4057-abe2-0f7548020fe6"],

Cell["\<\
While HyperIntica is the main (analytic) integration routine working under \
the hood of the STIntegrate function, it can also be used as a standalone \
function. It evaluates iterated integrals \[Integral]_0^\[Infinity] \
\[Ellipsis] \[Integral]_0^\[Infinity] f\\, dx_1 \[Ellipsis] dx_n in  for \
expressions built from hyperlogarithms, polylogarithms, logarithms, and \
rational functions, returning results in terms of multi-zeta values and \
hyperlogarithms in the original integrand f parameters (if any). The syntax \
is: (see example below)\
\>", "Notes",ExpressionUUID->"696ad114-9371-43f4-849e-16b73b30e852"],

Cell[BoxData[
 RowBox[{"HyperIntica", "[", 
  RowBox[{"integrand", ",", " ", "variables", ",", " ", 
   RowBox[{"\"\<Monitor\>\"", " ", "->", " ", "False"}]}], "]"}]], "Input",Exp\
ressionUUID->"eb5eb9df-a61b-4ee4-b6b0-44a5a0c7ffd3"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Details", "Section",ExpressionUUID->"cf22fbb2-bc83-483f-ba44-ccafbdfbd254"],

Cell["Required arguments", "Subsection",ExpressionUUID->"58cd77cf-a2c5-4e81-bdf1-994ecec4748e"],

Cell["\<\
The argument integrand accepts either a symbolic expression involving Hlog, \
Mpl, PolyLog, logarithms and/or rational functions. The argument \
variables\\,= {x_1, ..., x_n} is the ordered list of integration variables, \
each x_i integrated, left to right, from 0 to \[Infinity] by default.\
\>", "Text",ExpressionUUID->"9b9c0322-6b8b-49c9-91f0-566e2f4f7452"]
}, Open  ]],


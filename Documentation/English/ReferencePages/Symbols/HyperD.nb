Notebook[{

Cell[CellGroupData[{
Cell["HyperD", "ObjectName",ExpressionUUID->"a6f17b3c-6705-4389-bb7f-fa4b4f3315a7"],

Cell[BoxData[GridBox[{
   {Cell[TextData[{
     StyleBox["HyperD", "TI"],
     " \[LineSeparator]While HyperIntica is the main (analytic) integration \
routine working under the hood of the STIntegrate function, it can also be \
used as a standalone function."
    }], "TableText",ExpressionUUID->"42db186c-acdf-44a5-8664-a5adf1742b1f"]}
  },
  GridBoxAlignment->{"Columns" -> {{Left}}},
  GridBoxItemSize->{
   "Columns" -> {{Automatic}}, "Rows" -> {{Automatic}}}]], "Usage",
 CellID->1,ExpressionUUID->"347bb3eb-470b-4575-a9dd-7d95a9091b3b"],

Cell["\<\
While HyperIntica is the main (analytic) integration routine working under \
the hood of the STIntegrate function, it can also be used as a standalone \
function. It evaluates iterated integrals \[Integral]_0^\[Infinity] \
\[Ellipsis] \[Integral]_0^\[Infinity] f\\, dx_1 \[Ellipsis] dx_n in  for \
expressions built from hyperlogarithms, polylogarithms, logarithms, and \
rational functions, returning results in terms of multi-zeta values and \
hyperlogarithms in the original integrand f parameters (if any). The syntax \
is: (see example below)\
\>", "Notes",ExpressionUUID->"d252cb5b-c521-4607-8614-2a4d45e3be6c"],

Cell[BoxData[
 RowBox[{"HyperIntica", "[", 
  RowBox[{"integrand", ",", " ", "variables", ",", " ", 
   RowBox[{"\"\<Monitor\>\"", " ", "->", " ", "False"}]}], "]"}]], "Input",Exp\
ressionUUID->"c8726aa0-cca5-46b5-8034-ab76cc01139c"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Details", "Section",ExpressionUUID->"aee47f55-a3e0-4259-84d0-3a965923ab82"],

Cell["Derivatives", "Subsection",ExpressionUUID->"433fb51c-cf4c-436c-b7f4-3fe3ac4a2f52"],

Cell["\<\
HyperD[expr, var] computes the derivative of expr with respect to var, \
correctly implementing differentiation rules for Hlog and Mpl that the \
built-in Mathematica D[] does not handle. expr may contain Hlog, Mpl, \
PolyLog, logarithms, and algebraic functions, while var can appear in both \
the upper limit and the letters of hyperlogarithms. Some examples are: (see \
example below)\
\>", "Text",ExpressionUUID->"febe349c-f11a-4511-98f6-ce2bb695309e"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{"Differentiate", " ", 
    RowBox[{"Li", "\\", "textcolor"}], 
    RowBox[{"{", "gray", "}"}], 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"{", "}"}], "_", "2"}], "}"}], 
    RowBox[{"(", 
     RowBox[{"1", "-", 
      RowBox[{"x", "/", "u"}]}], ")"}], " ", "with", " ", "respect", " ", 
    "to", " ", "x"}], " ", "*)"}], "\n", "\t", 
  RowBox[{
   RowBox[{"HyperD", "[", 
    RowBox[{
     RowBox[{"Mpl", "[", 
      RowBox[{
       RowBox[{"{", "2", "}"}], ",", " ", 
       RowBox[{"{", 
        RowBox[{"1", " ", "-", " ", 
         RowBox[{"x", "/", "u"}]}], "}"}]}], "]"}], ",", " ", "x"}], "]"}], 
   "\n", "\t", 
   RowBox[{"(*", " ", 
    RowBox[{"Out", ":", " ", 
     RowBox[{"-", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{"Mpl", "[", 
         RowBox[{
          RowBox[{"{", "1", "}"}], ",", " ", 
          RowBox[{"{", 
           RowBox[{"1", " ", "-", " ", 
            RowBox[{"x", "/", "u"}]}], "}"}]}], "]"}], "/", 
        RowBox[{"(", 
         RowBox[{"u", 
          RowBox[{"(", 
           RowBox[{"1", " ", "-", " ", 
            RowBox[{"x", "/", "u"}]}], ")"}]}], ")"}]}], ")"}]}]}], " ", 
    "*)"}], "\n", "\t", "\n", "\t", 
   RowBox[{"(*", " ", 
    RowBox[{
     RowBox[{"Differentiate", " ", "Hlog", " ", "with", " ", "var"}], "-", 
     RowBox[{"dependent", " ", "letters"}]}], " ", "*)"}], "\n", "\t", 
   RowBox[{"HyperD", "[", 
    RowBox[{
     RowBox[{"Hlog", "[", 
      RowBox[{"z", ",", " ", 
       RowBox[{"{", 
        RowBox[{"a", ",", " ", "b"}], "}"}]}], "]"}], ",", " ", "a"}], "]"}], 
   "\n", "\t", 
   RowBox[{"(*", " ", 
    RowBox[{"Out", ":", " ", 
     RowBox[{
      RowBox[{
       RowBox[{"(", 
        RowBox[{
         RowBox[{"Hlog", "[", 
          RowBox[{"z", ",", " ", 
           RowBox[{"{", "a", "}"}]}], "]"}], " ", "-", " ", 
         RowBox[{"Hlog", "[", 
          RowBox[{"z", ",", " ", 
           RowBox[{"{", "b", "}"}]}], "]"}]}], ")"}], "/", 
       RowBox[{"(", 
        RowBox[{"a", " ", "-", " ", "b"}], ")"}]}], " ", "-", " ", 
      RowBox[{
       RowBox[{"Hlog", "[", 
        RowBox[{"z", ",", " ", 
         RowBox[{"{", "b", "}"}]}], "]"}], "/", 
       RowBox[{"(", 
        RowBox[{"z", "-", "a"}], ")"}]}]}]}], " ", "*)"}], "\n", "\t", "\n", 
   "\t", 
   RowBox[{"(*", " ", 
    RowBox[{"Product", " ", "involving", " ", "Mpl"}], " ", "*)"}], "\n", 
   "\t", 
   RowBox[{"HyperD", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"Log", "[", "x", "]"}], " ", 
      RowBox[{"Mpl", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"1", ",", "2"}], "}"}], ",", " ", 
        RowBox[{"{", 
         RowBox[{"x", ",", " ", "y"}], "}"}]}], "]"}]}], ",", " ", "x"}], 
    "]"}], "\n", "\t", 
   RowBox[{"(*", " ", 
    RowBox[{"Out", ":", " ", "\n", "    ", 
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{"Log", "[", "x", "]"}], "/", 
        RowBox[{"(", 
         RowBox[{"x", "-", "1"}], ")"}]}], " ", 
       RowBox[{"(", 
        RowBox[{
         RowBox[{
          RowBox[{"Mpl", "[", 
           RowBox[{
            RowBox[{"{", "2", "}"}], ",", " ", 
            RowBox[{"{", 
             RowBox[{"x", " ", "y"}], "}"}]}], "]"}], "/", "x"}], "-", 
         RowBox[{"(", 
          RowBox[{"Mpl", "[", 
           RowBox[{
            RowBox[{"{", "2", "}"}], ",", 
            RowBox[{"{", "y", "}"}]}], "]"}], ")"}]}], ")"}]}], " ", "+", " ", 
      RowBox[{
       RowBox[{"Mpl", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"1", ",", "2"}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{"x", ",", "y"}], "}"}]}], "]"}], "/", "x"}]}]}], " ", 
    "*)"}]}]}]], "Input",ExpressionUUID->"cba4856b-fd87-40f5-97d6-\
856c1c705886"]
}, Open  ]],


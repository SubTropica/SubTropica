Notebook[{

Cell[CellGroupData[{
Cell["HyperD", "ObjectName",ExpressionUUID->"82f88eb0-981f-470e-81e8-43c9e02b88c6"],

Cell[BoxData[GridBox[{
   {Cell[TextData[{
     StyleBox["HyperD", "TI"],
     " \[LineSeparator]While HyperIntica is the main (analytic) integration \
routine working under the hood of the STIntegrate function, it can also be \
used as a standalone function."
    }], "TableText",ExpressionUUID->"960c87d8-dba7-442e-ae07-16b342b73d9f"]}
  },
  GridBoxAlignment->{"Columns" -> {{Left}}},
  GridBoxItemSize->{
   "Columns" -> {{Automatic}}, "Rows" -> {{Automatic}}}]], "Usage",
 CellID->1,ExpressionUUID->"7cc9ede4-6a6a-4d3b-9e97-0898395a513c"],

Cell["\<\
While HyperIntica is the main (analytic) integration routine working under \
the hood of the STIntegrate function, it can also be used as a standalone \
function. It evaluates iterated integrals \[Integral]_0^\[Infinity] \
\[Ellipsis] \[Integral]_0^\[Infinity] f\\, dx_1 \[Ellipsis] dx_n in  for \
expressions built from hyperlogarithms, polylogarithms, logarithms, and \
rational functions, returning results in terms of multi-zeta values and \
hyperlogarithms in the original integrand f parameters (if any). The syntax \
is: (see example below)\
\>", "Notes",ExpressionUUID->"a6a4aeaf-1abb-4012-8f2b-3e7c9b8078e0"],

Cell[BoxData[
 RowBox[{"HyperIntica", "[", 
  RowBox[{"integrand", ",", " ", "variables", ",", " ", 
   RowBox[{"\"\<Monitor\>\"", " ", "->", " ", "False"}]}], "]"}]], "Input",Exp\
ressionUUID->"60fe3262-1afd-4897-8ece-b8ca90de6bd3"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Details", "Section",ExpressionUUID->"9abbf6be-52ec-4495-943e-701c0a4b3397"],

Cell["Derivatives", "Subsection",ExpressionUUID->"5a16e14f-f70b-4273-ba16-fe5bfef7080e"],

Cell["\<\
HyperD[expr, var] computes the derivative of expr with respect to var, \
correctly implementing differentiation rules for Hlog and Mpl that the \
built-in Mathematica D[] does not handle. expr may contain Hlog, Mpl, \
PolyLog, logarithms, and algebraic functions, while var can appear in both \
the upper limit and the letters of hyperlogarithms. Some examples are: (see \
example below)\
\>", "Text",ExpressionUUID->"c99f9d0d-496f-44b9-a886-a8b03ff30933"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{"Differentiate", " ", 
    RowBox[{"Li", "\\", "textcolor"}], 
    RowBox[{"{", "gray", "}"}], 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"{", "}"}], "_", "2"}], "}"}], 
    RowBox[{"(", 
     RowBox[{"1", "-", 
      RowBox[{"x", "/", "u"}]}], ")"}], " ", "with", " ", "respect", " ", 
    "to", " ", "x"}], " ", "*)"}], "\n", "\t", 
  RowBox[{
   RowBox[{"HyperD", "[", 
    RowBox[{
     RowBox[{"Mpl", "[", 
      RowBox[{
       RowBox[{"{", "2", "}"}], ",", " ", 
       RowBox[{"{", 
        RowBox[{"1", " ", "-", " ", 
         RowBox[{"x", "/", "u"}]}], "}"}]}], "]"}], ",", " ", "x"}], "]"}], 
   "\n", "\t", 
   RowBox[{"(*", " ", 
    RowBox[{"Out", ":", " ", 
     RowBox[{"-", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{"Mpl", "[", 
         RowBox[{
          RowBox[{"{", "1", "}"}], ",", " ", 
          RowBox[{"{", 
           RowBox[{"1", " ", "-", " ", 
            RowBox[{"x", "/", "u"}]}], "}"}]}], "]"}], "/", 
        RowBox[{"(", 
         RowBox[{"u", 
          RowBox[{"(", 
           RowBox[{"1", " ", "-", " ", 
            RowBox[{"x", "/", "u"}]}], ")"}]}], ")"}]}], ")"}]}]}], " ", 
    "*)"}], "\n", "\t", "\n", "\t", 
   RowBox[{"(*", " ", 
    RowBox[{
     RowBox[{"Differentiate", " ", "Hlog", " ", "with", " ", "var"}], "-", 
     RowBox[{"dependent", " ", "letters"}]}], " ", "*)"}], "\n", "\t", 
   RowBox[{"HyperD", "[", 
    RowBox[{
     RowBox[{"Hlog", "[", 
      RowBox[{"z", ",", " ", 
       RowBox[{"{", 
        RowBox[{"a", ",", " ", "b"}], "}"}]}], "]"}], ",", " ", "a"}], "]"}], 
   "\n", "\t", 
   RowBox[{"(*", " ", 
    RowBox[{"Out", ":", " ", 
     RowBox[{
      RowBox[{
       RowBox[{"(", 
        RowBox[{
         RowBox[{"Hlog", "[", 
          RowBox[{"z", ",", " ", 
           RowBox[{"{", "a", "}"}]}], "]"}], " ", "-", " ", 
         RowBox[{"Hlog", "[", 
          RowBox[{"z", ",", " ", 
           RowBox[{"{", "b", "}"}]}], "]"}]}], ")"}], "/", 
       RowBox[{"(", 
        RowBox[{"a", " ", "-", " ", "b"}], ")"}]}], " ", "-", " ", 
      RowBox[{
       RowBox[{"Hlog", "[", 
        RowBox[{"z", ",", " ", 
         RowBox[{"{", "b", "}"}]}], "]"}], "/", 
       RowBox[{"(", 
        RowBox[{"z", "-", "a"}], ")"}]}]}]}], " ", "*)"}], "\n", "\t", "\n", 
   "\t", 
   RowBox[{"(*", " ", 
    RowBox[{"Product", " ", "involving", " ", "Mpl"}], " ", "*)"}], "\n", 
   "\t", 
   RowBox[{"HyperD", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"Log", "[", "x", "]"}], " ", 
      RowBox[{"Mpl", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"1", ",", "2"}], "}"}], ",", " ", 
        RowBox[{"{", 
         RowBox[{"x", ",", " ", "y"}], "}"}]}], "]"}]}], ",", " ", "x"}], 
    "]"}], "\n", "\t", 
   RowBox[{"(*", " ", 
    RowBox[{"Out", ":", " ", "\n", "    ", 
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{"Log", "[", "x", "]"}], "/", 
        RowBox[{"(", 
         RowBox[{"x", "-", "1"}], ")"}]}], " ", 
       RowBox[{"(", 
        RowBox[{
         RowBox[{
          RowBox[{"Mpl", "[", 
           RowBox[{
            RowBox[{"{", "2", "}"}], ",", " ", 
            RowBox[{"{", 
             RowBox[{"x", " ", "y"}], "}"}]}], "]"}], "/", "x"}], "-", 
         RowBox[{"(", 
          RowBox[{"Mpl", "[", 
           RowBox[{
            RowBox[{"{", "2", "}"}], ",", 
            RowBox[{"{", "y", "}"}]}], "]"}], ")"}]}], ")"}]}], " ", "+", " ", 
      RowBox[{
       RowBox[{"Mpl", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"1", ",", "2"}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{"x", ",", "y"}], "}"}]}], "]"}], "/", "x"}]}]}], " ", 
    "*)"}]}]}]], "Input",ExpressionUUID->"12b62fb8-47b1-4ef5-bc49-\
e5e84ea9ac8c"]
}, Open  ]],


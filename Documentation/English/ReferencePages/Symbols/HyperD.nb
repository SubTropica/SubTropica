Notebook[{

Cell[CellGroupData[{
Cell["HyperD", "ObjectName",ExpressionUUID->"769ad77f-a344-4faa-99fe-7a3c71ac02dc"],

Cell[BoxData[GridBox[{
   {Cell[TextData[{
     StyleBox["HyperD", "TI"],
     " \[LineSeparator]While HyperIntica is the main (analytic) integration \
routine working under the hood of the STIntegrate function, it can also be \
used as a standalone function."
    }], "TableText",ExpressionUUID->"83b3a10a-8b92-45e1-a3e9-29c97faa87c1"]}
  },
  GridBoxAlignment->{"Columns" -> {{Left}}},
  GridBoxItemSize->{
   "Columns" -> {{Automatic}}, "Rows" -> {{Automatic}}}]], "Usage",
 CellID->1,ExpressionUUID->"ea7292d2-5960-42af-8dc8-59d34316b4cd"],

Cell["\<\
While HyperIntica is the main (analytic) integration routine working under \
the hood of the STIntegrate function, it can also be used as a standalone \
function. It evaluates iterated integrals \[Integral]_0^\[Infinity] \
\[Ellipsis] \[Integral]_0^\[Infinity] f\\, dx_1 \[Ellipsis] dx_n in  for \
expressions built from hyperlogarithms, polylogarithms, logarithms, and \
rational functions, returning results in terms of multi-zeta values and \
hyperlogarithms in the original integrand f parameters (if any). The syntax \
is: (see example below)\
\>", "Notes",ExpressionUUID->"8ddecdfd-80d3-4bad-9fc5-2ae6dfbad959"],

Cell[BoxData[
 RowBox[{"HyperIntica", "[", 
  RowBox[{"integrand", ",", " ", "variables", ",", " ", 
   RowBox[{"\"\<Monitor\>\"", " ", "->", " ", "False"}]}], "]"}]], "Input",Exp\
ressionUUID->"f3ba897a-0ee5-41c8-8a95-2c586ff44e8a"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Details", "Section",ExpressionUUID->"98d3c110-42b0-45e7-90fc-05fb09e7dd67"],

Cell["Derivatives", "Subsection",ExpressionUUID->"9485137a-b06c-4933-912e-4d353e2d1878"],

Cell["\<\
HyperD[expr, var] computes the derivative of expr with respect to var, \
correctly implementing differentiation rules for Hlog and Mpl that the \
built-in Mathematica D[] does not handle. expr may contain Hlog, Mpl, \
PolyLog, logarithms, and algebraic functions, while var can appear in both \
the upper limit and the letters of hyperlogarithms. Some examples are: (see \
example below)\
\>", "Text",ExpressionUUID->"e3e11db9-179d-48b9-9335-4c919415d09e"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{"Differentiate", " ", 
    RowBox[{"Li", "\\", "textcolor"}], 
    RowBox[{"{", "gray", "}"}], 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"{", "}"}], "_", "2"}], "}"}], 
    RowBox[{"(", 
     RowBox[{"1", "-", 
      RowBox[{"x", "/", "u"}]}], ")"}], " ", "with", " ", "respect", " ", 
    "to", " ", "x"}], " ", "*)"}], "\n", "\t", 
  RowBox[{
   RowBox[{"HyperD", "[", 
    RowBox[{
     RowBox[{"Mpl", "[", 
      RowBox[{
       RowBox[{"{", "2", "}"}], ",", " ", 
       RowBox[{"{", 
        RowBox[{"1", " ", "-", " ", 
         RowBox[{"x", "/", "u"}]}], "}"}]}], "]"}], ",", " ", "x"}], "]"}], 
   "\n", "\t", 
   RowBox[{"(*", " ", 
    RowBox[{"Out", ":", " ", 
     RowBox[{"-", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{"Mpl", "[", 
         RowBox[{
          RowBox[{"{", "1", "}"}], ",", " ", 
          RowBox[{"{", 
           RowBox[{"1", " ", "-", " ", 
            RowBox[{"x", "/", "u"}]}], "}"}]}], "]"}], "/", 
        RowBox[{"(", 
         RowBox[{"u", 
          RowBox[{"(", 
           RowBox[{"1", " ", "-", " ", 
            RowBox[{"x", "/", "u"}]}], ")"}]}], ")"}]}], ")"}]}]}], " ", 
    "*)"}], "\n", "\t", "\n", "\t", 
   RowBox[{"(*", " ", 
    RowBox[{
     RowBox[{"Differentiate", " ", "Hlog", " ", "with", " ", "var"}], "-", 
     RowBox[{"dependent", " ", "letters"}]}], " ", "*)"}], "\n", "\t", 
   RowBox[{"HyperD", "[", 
    RowBox[{
     RowBox[{"Hlog", "[", 
      RowBox[{"z", ",", " ", 
       RowBox[{"{", 
        RowBox[{"a", ",", " ", "b"}], "}"}]}], "]"}], ",", " ", "a"}], "]"}], 
   "\n", "\t", 
   RowBox[{"(*", " ", 
    RowBox[{"Out", ":", " ", 
     RowBox[{
      RowBox[{
       RowBox[{"(", 
        RowBox[{
         RowBox[{"Hlog", "[", 
          RowBox[{"z", ",", " ", 
           RowBox[{"{", "a", "}"}]}], "]"}], " ", "-", " ", 
         RowBox[{"Hlog", "[", 
          RowBox[{"z", ",", " ", 
           RowBox[{"{", "b", "}"}]}], "]"}]}], ")"}], "/", 
       RowBox[{"(", 
        RowBox[{"a", " ", "-", " ", "b"}], ")"}]}], " ", "-", " ", 
      RowBox[{
       RowBox[{"Hlog", "[", 
        RowBox[{"z", ",", " ", 
         RowBox[{"{", "b", "}"}]}], "]"}], "/", 
       RowBox[{"(", 
        RowBox[{"z", "-", "a"}], ")"}]}]}]}], " ", "*)"}], "\n", "\t", "\n", 
   "\t", 
   RowBox[{"(*", " ", 
    RowBox[{"Product", " ", "involving", " ", "Mpl"}], " ", "*)"}], "\n", 
   "\t", 
   RowBox[{"HyperD", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"Log", "[", "x", "]"}], " ", 
      RowBox[{"Mpl", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"1", ",", "2"}], "}"}], ",", " ", 
        RowBox[{"{", 
         RowBox[{"x", ",", " ", "y"}], "}"}]}], "]"}]}], ",", " ", "x"}], 
    "]"}], "\n", "\t", 
   RowBox[{"(*", " ", 
    RowBox[{"Out", ":", " ", "\n", "    ", 
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{"Log", "[", "x", "]"}], "/", 
        RowBox[{"(", 
         RowBox[{"x", "-", "1"}], ")"}]}], " ", 
       RowBox[{"(", 
        RowBox[{
         RowBox[{
          RowBox[{"Mpl", "[", 
           RowBox[{
            RowBox[{"{", "2", "}"}], ",", " ", 
            RowBox[{"{", 
             RowBox[{"x", " ", "y"}], "}"}]}], "]"}], "/", "x"}], "-", 
         RowBox[{"(", 
          RowBox[{"Mpl", "[", 
           RowBox[{
            RowBox[{"{", "2", "}"}], ",", 
            RowBox[{"{", "y", "}"}]}], "]"}], ")"}]}], ")"}]}], " ", "+", " ", 
      RowBox[{
       RowBox[{"Mpl", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"1", ",", "2"}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{"x", ",", "y"}], "}"}]}], "]"}], "/", "x"}]}]}], " ", 
    "*)"}]}]}]], "Input",ExpressionUUID->"b1627c6b-9f59-4634-8607-\
bacc737460ab"]
}, Open  ]],


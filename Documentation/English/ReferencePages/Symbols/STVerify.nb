Notebook[{

Cell[CellGroupData[{
Cell["STVerify", "ObjectName",ExpressionUUID->"501b4646-c695-4a4d-a196-a6f1de87d753"],

Cell[BoxData[GridBox[{
   {Cell[TextData[{
     StyleBox["STVerify", "TI"],
     " \[LineSeparator]STVerify cross-checks a symbolic result from \
STIntegrate against a numerical evaluation."
    }], "TableText",ExpressionUUID->"da9a05b6-f435-472c-967e-c4f0e7aa3938"]}
  },
  GridBoxAlignment->{"Columns" -> {{Left}}},
  GridBoxItemSize->{
   "Columns" -> {{Automatic}}, "Rows" -> {{Automatic}}}]], "Usage",
 CellID->1,ExpressionUUID->"489f9e2c-818d-4ad2-80ec-ec7f3f31637a"],

Cell["\<\
STVerify cross-checks a symbolic result from STIntegrate against a numerical \
evaluation. It automatically generates a Euclidean kinematic point, runs \
STNIntegrate for the numerical side and STToGinsh for the symbolic side, and \
compares Laurent coefficients order by order. The syntax is: (see example \
below)\
\>", "Notes",ExpressionUUID->"398423c7-51a3-4221-994e-c6e9632aad00"],

Cell[BoxData[
 RowBox[{"STVerify", "[", 
  RowBox[{"input", ",", " ", "result", "\n", "    ", ",", " ", 
   RowBox[{"\"\<Order\>\"", "      ", "->", " ", "0"}], "\n", "    ", ",", 
   " ", 
   RowBox[{"\"\<Dimension\>\"", "  ", "->", " ", 
    RowBox[{"4", " ", "-", " ", 
     RowBox[{"2", " ", "eps"}]}]}], " ", "\n", "    ", ",", " ", 
   RowBox[{"\"\<Tolerance\>\"", "  ", "->", " ", 
    RowBox[{"10", "^", 
     RowBox[{"-", "3"}]}]}], "\n", "    ", ",", " ", 
   RowBox[{"\"\<MaxEval\>\"", "    ", "->", " ", "Automatic"}], "\n", "    ", 
   ",", " ", 
   RowBox[{"\"\<Accuracy\>\"", "   ", "->", " ", 
    RowBox[{"10", "^", 
     RowBox[{"-", "4"}]}]}], "\n", "    ", ",", " ", 
   RowBox[{"\"\<Integrator\>\"", " ", "->", " ", "\"\<Qmc\>\""}], "\n", 
   "    ", ",", " ", 
   RowBox[{"\"\<Method\>\"", "     ", "->", " ", "\"\<pySecDec\>\""}], "\n", 
   "    ", ",", " ", 
   RowBox[{"\"\<Verbose\>\"", "    ", "->", " ", "False"}]}], "]"}]], "Input",\
ExpressionUUID->"ffa8f8f3-8028-480d-bd6b-120e3c5b22fd"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Details", "Section",ExpressionUUID->"39af080b-5041-4208-ac80-0ce74cde0d7f"],

Cell["Options", "Subsection",ExpressionUUID->"fb395258-8665-432b-895b-dc24897fbf56"],

Cell["\<\
\"Tolerance\" (default 10^{-3}) sets the threshold for the relative error \
between numerical and symbolic coefficients. \"MaxEval\" -> Automatic \
defaults to 10^6 for one-loop integrals and 10^7 otherwise. The remaining \
options are inherited from STNIntegrate.\
\>", "Text",ExpressionUUID->"a783576f-e315-46b2-addd-f811f69f0a5e"],

Cell["Return value", "Subsection",ExpressionUUID->"b1b4ebc9-5327-4de7-af0f-f79fc429d114"],

Cell["\<\
An Association with keys \"pass\" (True/False), \"reason\", \"maxRelErr\", \
\"relErr\" (per-coefficient relative errors), \"coefficients\" (detailed \
comparison at each \[CurlyEpsilon]-order), \"kinPoint\" (the kinematic point \
used), and \"symbolic\" (the evaluated symbolic result).\
\>", "Text",ExpressionUUID->"2f6bdad0-eaa7-44f6-abfd-a7b212e8478a"]
}, Open  ]],


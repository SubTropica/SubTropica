Notebook[{

Cell[CellGroupData[{
Cell["STToGinsh", "ObjectName",ExpressionUUID->"b1765f6a-e8d7-46e3-be6f-48d97fcc8f2e"],

Cell[BoxData[GridBox[{
   {Cell[TextData[{
     StyleBox["STToGinsh", "TI"],
     " \[LineSeparator]STNIntegrate numerically evaluates integrals."
    }], "TableText",ExpressionUUID->"188e3248-4970-4c5c-9780-0c5f45d1d447"]}
  },
  GridBoxAlignment->{"Columns" -> {{Left}}},
  GridBoxItemSize->{
   "Columns" -> {{Automatic}}, "Rows" -> {{Automatic}}}]], "Usage",
 CellID->1,ExpressionUUID->"cd8e6b41-b33e-4da3-8b7e-cb216b9ed7f0"],

Cell["\<\
STNIntegrate numerically evaluates integrals. It accepts all the same input \
formats as STIntegrate (Forms~1--3), including generic parametric \
representations.\
\>", "Notes",ExpressionUUID->"1a01283a-e0d4-4d40-944c-604b44cb782b"],

Cell[BoxData[
 RowBox[{"STNIntegrate", "[", 
  RowBox[{"input", "\n", "    ", ",", " ", 
   RowBox[{"\"\<Method\>\"", "             ", "->", " ", "\"\<pySecDec\>\""}],
    "\n", "    ", ",", " ", 
   RowBox[{"\"\<Substitutions\>\"", "     ", "->", " ", 
    RowBox[{"{", "}"}]}], "\n", "    ", ",", " ", 
   RowBox[{"\"\<Order\>\"", "              ", "->", " ", "0"}], "\n", "    ", 
   ",", " ", 
   RowBox[{"\"\<MaxEval\>\"", "            ", "->", " ", 
    RowBox[{"10", "^", "7"}]}], "\n", "    ", ",", " ", 
   RowBox[{"\"\<Accuracy\>\"", "           ", "->", " ", 
    RowBox[{"10", "^", 
     RowBox[{"-", "4"}]}]}], "\n", "    ", ",", " ", 
   RowBox[{"\"\<Integrator\>\"", "         ", "->", " ", "\"\<Qmc\>\""}], 
   "\n", "    ", ",", " ", 
   RowBox[{"\"\<ContourDeformation\>\"", " ", "->", " ", "True"}], "\n", 
   "    ", ",", " ", 
   RowBox[{"\"\<Verbose\>\"", "            ", "->", " ", "False"}], "\n", 
   "    ", ",", " ", 
   RowBox[{"\"\<Dimension\>\"", "          ", "->", " ", 
    RowBox[{"4", " ", "-", " ", 
     RowBox[{"2", " ", "eps"}]}]}], "\n", "    ", ",", " ", 
   RowBox[{"\"\<Normalization\>\"", "      ", "->", " ", "Automatic"}], "\n", 
   "    ", ",", " ", 
   RowBox[{"\"\<Exponents\>\"", "          ", "->", " ", "Automatic"}], "\n", 
   "    ", ",", " ", 
   RowBox[{"\"\<Substitutions\>\"", "      ", "->", " ", 
    RowBox[{"{", "}"}]}], "\n", "    ", ",", " ", 
   RowBox[{"\"\<CacheDirectory\>\"", "     ", "->", " ", "Automatic"}]}], 
  "]"}]], "Input",ExpressionUUID->"38042c78-d766-4387-b9bb-4a8c51201bd1"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Details", "Section",ExpressionUUID->"532c0a9e-6104-4ac1-aa0d-baaf84761295"],

Cell["Numerical evaluation of hyperlogarithms: STToGinsh", "Subsection",ExpressionUUID->"7e90d02b-b021-4fe2-800c-a9be14a1e630"],

Cell["\<\
STToGinsh[expr] numerically evaluates hyperlogarithm expressions via ginsh, \
the GiNaC interactive shell (requires ginsh installed and on the system \
path). It accepts Hlog, Mpl, mzv/zeta, and Log objects, converts them to \
GiNaC format internally, and returns a floating-point approximation. \
Expressions containing none of these are returned unchanged. A simple example \
of usage is:  (see example below)\
\>", "Text",ExpressionUUID->"dfff7bd2-1685-4a19-bb05-68885dd8c714"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
   "Evaluate", " ", "an", " ", "expression", " ", "with", " ", "Hlogs", " ", 
    "and", " ", "MZVs"}], " ", "*)"}], "\n", "\t", 
  RowBox[{
   RowBox[{"result", " ", "=", " ", 
    RowBox[{"STToGinsh", "[", 
     RowBox[{
      RowBox[{"3", " ", 
       RowBox[{"Hlog", "[", 
        RowBox[{"2", ",", " ", 
         RowBox[{"{", 
          RowBox[{"0", ",", " ", "1"}], "}"}]}], "]"}]}], " ", "+", " ", 
      RowBox[{"mzv", "[", "3", "]"}]}], "]"}]}], "\n", "    ", 
   RowBox[{"(*", " ", 
    RowBox[{"Out", ":", " ", 
     RowBox[{
      RowBox[{"-", "6.20015"}], " ", "+", " ", 
      RowBox[{"6.53276", " ", "I"}]}]}], " ", "*)"}]}]}]], "Input",ExpressionU\
UID->"12fefbdd-b3c6-416b-9330-0abbc58702b5"]
}, Open  ]],


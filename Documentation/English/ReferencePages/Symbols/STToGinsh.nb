Notebook[{

Cell[CellGroupData[{
Cell["STToGinsh", "ObjectName",ExpressionUUID->"8d004b33-822b-44e1-9e3f-aeb3bd43120f"],

Cell[BoxData[GridBox[{
   {Cell[TextData[{
     StyleBox["STToGinsh", "TI"],
     " \[LineSeparator]STNIntegrate numerically evaluates integrals."
    }], "TableText",ExpressionUUID->"b358c623-3bca-4e8b-8d26-0d5da38b9ab9"]}
  },
  GridBoxAlignment->{"Columns" -> {{Left}}},
  GridBoxItemSize->{
   "Columns" -> {{Automatic}}, "Rows" -> {{Automatic}}}]], "Usage",
 CellID->1,ExpressionUUID->"2b228811-710b-4b50-81e2-a0b0e390aae3"],

Cell["\<\
STNIntegrate numerically evaluates integrals. It accepts all the same input \
formats as STIntegrate (Forms~1--3), including generic parametric \
representations.\
\>", "Notes",ExpressionUUID->"4ac0b17e-7772-4ef0-929b-aca451ada873"],

Cell[BoxData[
 RowBox[{"STNIntegrate", "[", 
  RowBox[{"input", "\n", "    ", ",", " ", 
   RowBox[{"\"\<Method\>\"", "             ", "->", " ", "\"\<pySecDec\>\""}],
    "\n", "    ", ",", " ", 
   RowBox[{"\"\<Substitutions\>\"", "     ", "->", " ", 
    RowBox[{"{", "}"}]}], "\n", "    ", ",", " ", 
   RowBox[{"\"\<Order\>\"", "              ", "->", " ", "0"}], "\n", "    ", 
   ",", " ", 
   RowBox[{"\"\<MaxEval\>\"", "            ", "->", " ", 
    RowBox[{"10", "^", "7"}]}], "\n", "    ", ",", " ", 
   RowBox[{"\"\<Accuracy\>\"", "           ", "->", " ", 
    RowBox[{"10", "^", 
     RowBox[{"-", "4"}]}]}], "\n", "    ", ",", " ", 
   RowBox[{"\"\<Integrator\>\"", "         ", "->", " ", "\"\<Qmc\>\""}], 
   "\n", "    ", ",", " ", 
   RowBox[{"\"\<ContourDeformation\>\"", " ", "->", " ", "True"}], "\n", 
   "    ", ",", " ", 
   RowBox[{"\"\<Verbose\>\"", "            ", "->", " ", "False"}], "\n", 
   "    ", ",", " ", 
   RowBox[{"\"\<Dimension\>\"", "          ", "->", " ", 
    RowBox[{"4", " ", "-", " ", 
     RowBox[{"2", " ", "eps"}]}]}], "\n", "    ", ",", " ", 
   RowBox[{"\"\<Normalization\>\"", "      ", "->", " ", "Automatic"}], "\n", 
   "    ", ",", " ", 
   RowBox[{"\"\<Exponents\>\"", "          ", "->", " ", "Automatic"}], "\n", 
   "    ", ",", " ", 
   RowBox[{"\"\<Substitutions\>\"", "      ", "->", " ", 
    RowBox[{"{", "}"}]}], "\n", "    ", ",", " ", 
   RowBox[{"\"\<CacheDirectory\>\"", "     ", "->", " ", "Automatic"}]}], 
  "]"}]], "Input",ExpressionUUID->"50e333c0-e991-475a-9340-548b89c34337"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Details", "Section",ExpressionUUID->"2355d834-95d3-4c5c-8248-4bff428d5613"],

Cell["Numerical evaluation of hyperlogarithms: STToGinsh", "Subsection",ExpressionUUID->"c4d90211-5858-430a-8e30-412b49754385"],

Cell["\<\
STToGinsh[expr] numerically evaluates hyperlogarithm expressions via ginsh, \
the GiNaC interactive shell (requires ginsh installed and on the system \
path). It accepts Hlog, Mpl, mzv/zeta, and Log objects, converts them to \
GiNaC format internally, and returns a floating-point approximation. \
Expressions containing none of these are returned unchanged. A simple example \
of usage is:  (see example below)\
\>", "Text",ExpressionUUID->"6aeee528-9f81-4db6-864f-415850947775"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
   "Evaluate", " ", "an", " ", "expression", " ", "with", " ", "Hlogs", " ", 
    "and", " ", "MZVs"}], " ", "*)"}], "\n", "\t", 
  RowBox[{
   RowBox[{"result", " ", "=", " ", 
    RowBox[{"STToGinsh", "[", 
     RowBox[{
      RowBox[{"3", " ", 
       RowBox[{"Hlog", "[", 
        RowBox[{"2", ",", " ", 
         RowBox[{"{", 
          RowBox[{"0", ",", " ", "1"}], "}"}]}], "]"}]}], " ", "+", " ", 
      RowBox[{"mzv", "[", "3", "]"}]}], "]"}]}], "\n", "    ", 
   RowBox[{"(*", " ", 
    RowBox[{"Out", ":", " ", 
     RowBox[{
      RowBox[{"-", "6.20015"}], " ", "+", " ", 
      RowBox[{"6.53276", " ", "I"}]}]}], " ", "*)"}]}]}]], "Input",ExpressionU\
UID->"9f5dc140-f0c0-4a39-ba55-bba7788137b5"]
}, Open  ]],


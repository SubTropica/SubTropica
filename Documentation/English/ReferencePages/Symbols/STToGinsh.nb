Notebook[{

Cell[CellGroupData[{
Cell["STToGinsh", "ObjectName",ExpressionUUID->"95cb279f-703a-4d06-813e-328ac4aa2c7b"],

Cell[BoxData[GridBox[{
   {Cell[TextData[{
     StyleBox["STToGinsh", "TI"],
     " \[LineSeparator]STNIntegrate numerically evaluates integrals."
    }], "TableText",ExpressionUUID->"333ed241-596d-43c7-b3eb-f5ef82212e50"]}
  },
  GridBoxAlignment->{"Columns" -> {{Left}}},
  GridBoxItemSize->{
   "Columns" -> {{Automatic}}, "Rows" -> {{Automatic}}}]], "Usage",
 CellID->1,ExpressionUUID->"c0bc9535-b65d-47ff-9061-3df8fddbfe4d"],

Cell["\<\
STNIntegrate numerically evaluates integrals. It accepts all the same input \
formats as STIntegrate (Forms~1--3), including generic parametric \
representations.\
\>", "Notes",ExpressionUUID->"149d8d3c-6e76-404a-889a-33c058e177f8"],

Cell[BoxData[
 RowBox[{"STNIntegrate", "[", 
  RowBox[{"input", "\n", "    ", ",", " ", 
   RowBox[{"\"\<Method\>\"", "             ", "->", " ", "\"\<pySecDec\>\""}],
    "\n", "    ", ",", " ", 
   RowBox[{"\"\<Substitutions\>\"", "     ", "->", " ", 
    RowBox[{"{", "}"}]}], "\n", "    ", ",", " ", 
   RowBox[{"\"\<Order\>\"", "              ", "->", " ", "0"}], "\n", "    ", 
   ",", " ", 
   RowBox[{"\"\<MaxEval\>\"", "            ", "->", " ", 
    RowBox[{"10", "^", "7"}]}], "\n", "    ", ",", " ", 
   RowBox[{"\"\<Accuracy\>\"", "           ", "->", " ", 
    RowBox[{"10", "^", 
     RowBox[{"-", "4"}]}]}], "\n", "    ", ",", " ", 
   RowBox[{"\"\<Integrator\>\"", "         ", "->", " ", "\"\<Qmc\>\""}], 
   "\n", "    ", ",", " ", 
   RowBox[{"\"\<ContourDeformation\>\"", " ", "->", " ", "True"}], "\n", 
   "    ", ",", " ", 
   RowBox[{"\"\<Verbose\>\"", "            ", "->", " ", "False"}], "\n", 
   "    ", ",", " ", 
   RowBox[{"\"\<Dimension\>\"", "          ", "->", " ", 
    RowBox[{"4", " ", "-", " ", 
     RowBox[{"2", " ", "eps"}]}]}], "\n", "    ", ",", " ", 
   RowBox[{"\"\<Normalization\>\"", "      ", "->", " ", "Automatic"}], "\n", 
   "    ", ",", " ", 
   RowBox[{"\"\<Exponents\>\"", "          ", "->", " ", "Automatic"}], "\n", 
   "    ", ",", " ", 
   RowBox[{"\"\<Substitutions\>\"", "      ", "->", " ", 
    RowBox[{"{", "}"}]}], "\n", "    ", ",", " ", 
   RowBox[{"\"\<CacheDirectory\>\"", "     ", "->", " ", "Automatic"}]}], 
  "]"}]], "Input",ExpressionUUID->"541cebcc-963c-44e9-975f-d8296cefdee7"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Details", "Section",ExpressionUUID->"829b8918-572f-4711-9232-d2e929fa4816"],

Cell["Numerical evaluation of hyperlogarithms: STToGinsh", "Subsection",ExpressionUUID->"989dabb0-720e-4e6e-aa29-96ce9ac40a63"],

Cell["\<\
STToGinsh[expr] numerically evaluates hyperlogarithm expressions via ginsh, \
the GiNaC interactive shell (requires ginsh installed and on the system \
path). It accepts Hlog, Mpl, mzv/zeta, and Log objects, converts them to \
GiNaC format internally, and returns a floating-point approximation. \
Expressions containing none of these are returned unchanged. A simple example \
of usage is:  (see example below)\
\>", "Text",ExpressionUUID->"24449a09-6ba6-4499-a551-f4b6ca54017a"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
   "Evaluate", " ", "an", " ", "expression", " ", "with", " ", "Hlogs", " ", 
    "and", " ", "MZVs"}], " ", "*)"}], "\n", "\t", 
  RowBox[{
   RowBox[{"result", " ", "=", " ", 
    RowBox[{"STToGinsh", "[", 
     RowBox[{
      RowBox[{"3", " ", 
       RowBox[{"Hlog", "[", 
        RowBox[{"2", ",", " ", 
         RowBox[{"{", 
          RowBox[{"0", ",", " ", "1"}], "}"}]}], "]"}]}], " ", "+", " ", 
      RowBox[{"mzv", "[", "3", "]"}]}], "]"}]}], "\n", "    ", 
   RowBox[{"(*", " ", 
    RowBox[{"Out", ":", " ", 
     RowBox[{
      RowBox[{"-", "6.20015"}], " ", "+", " ", 
      RowBox[{"6.53276", " ", "I"}]}]}], " ", "*)"}]}]}]], "Input",ExpressionU\
UID->"971e0f3b-9177-436f-810d-b8b068b6528d"]
}, Open  ]],


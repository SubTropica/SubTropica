Notebook[{

Cell[CellGroupData[{
Cell["STToGinsh", "ObjectName",ExpressionUUID->"25200b80-f51b-421e-bfd8-09f37c75c2b4"],

Cell[BoxData[GridBox[{
   {Cell[TextData[{
     StyleBox["STToGinsh", "TI"],
     " \[LineSeparator]STNIntegrate numerically evaluates integrals."
    }], "TableText",ExpressionUUID->"6804fc23-238a-4377-8a64-b11c71ed6da7"]}
  },
  GridBoxAlignment->{"Columns" -> {{Left}}},
  GridBoxItemSize->{
   "Columns" -> {{Automatic}}, "Rows" -> {{Automatic}}}]], "Usage",
 CellID->1,ExpressionUUID->"b7b78524-5bae-425e-bf1e-b4d6da86e38d"],

Cell["\<\
STNIntegrate numerically evaluates integrals. It accepts all the same input \
formats as STIntegrate (Forms~1--3), including generic parametric \
representations.\
\>", "Notes",ExpressionUUID->"34d93f52-43fa-45ab-9aad-66add729d8d4"],

Cell[BoxData[
 RowBox[{"STNIntegrate", "[", 
  RowBox[{"input", "\n", "    ", ",", " ", 
   RowBox[{"\"\<Method\>\"", "             ", "->", " ", "\"\<pySecDec\>\""}],
    "\n", "    ", ",", " ", 
   RowBox[{"\"\<Substitutions\>\"", "     ", "->", " ", 
    RowBox[{"{", "}"}]}], "\n", "    ", ",", " ", 
   RowBox[{"\"\<Order\>\"", "              ", "->", " ", "0"}], "\n", "    ", 
   ",", " ", 
   RowBox[{"\"\<MaxEval\>\"", "            ", "->", " ", 
    RowBox[{"10", "^", "7"}]}], "\n", "    ", ",", " ", 
   RowBox[{"\"\<Accuracy\>\"", "           ", "->", " ", 
    RowBox[{"10", "^", 
     RowBox[{"-", "4"}]}]}], "\n", "    ", ",", " ", 
   RowBox[{"\"\<Integrator\>\"", "         ", "->", " ", "\"\<Qmc\>\""}], 
   "\n", "    ", ",", " ", 
   RowBox[{"\"\<ContourDeformation\>\"", " ", "->", " ", "True"}], "\n", 
   "    ", ",", " ", 
   RowBox[{"\"\<Verbose\>\"", "            ", "->", " ", "False"}], "\n", 
   "    ", ",", " ", 
   RowBox[{"\"\<Dimension\>\"", "          ", "->", " ", 
    RowBox[{"4", " ", "-", " ", 
     RowBox[{"2", " ", "eps"}]}]}], "\n", "    ", ",", " ", 
   RowBox[{"\"\<Normalization\>\"", "      ", "->", " ", "Automatic"}], "\n", 
   "    ", ",", " ", 
   RowBox[{"\"\<Exponents\>\"", "          ", "->", " ", "Automatic"}], "\n", 
   "    ", ",", " ", 
   RowBox[{"\"\<Substitutions\>\"", "      ", "->", " ", 
    RowBox[{"{", "}"}]}], "\n", "    ", ",", " ", 
   RowBox[{"\"\<CacheDirectory\>\"", "     ", "->", " ", "Automatic"}]}], 
  "]"}]], "Input",ExpressionUUID->"49d4d331-8b7c-4249-8cf3-9db2e101e49a"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Details", "Section",ExpressionUUID->"1a39ea00-caa5-4264-87a2-4d4c001467ce"],

Cell["Numerical evaluation of hyperlogarithms: STToGinsh", "Subsection",ExpressionUUID->"19747ff5-56bc-4c32-98e4-748963c17d7c"],

Cell["\<\
STToGinsh[expr] numerically evaluates hyperlogarithm expressions via ginsh, \
the GiNaC interactive shell (requires ginsh installed and on the system \
path). It accepts Hlog, Mpl, mzv/zeta, and Log objects, converts them to \
GiNaC format internally, and returns a floating-point approximation. \
Expressions containing none of these are returned unchanged. A simple example \
of usage is:  (see example below)\
\>", "Text",ExpressionUUID->"9b2e710b-3804-48d5-9d10-8dd826ce414c"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
   "Evaluate", " ", "an", " ", "expression", " ", "with", " ", "Hlogs", " ", 
    "and", " ", "MZVs"}], " ", "*)"}], "\n", "\t", 
  RowBox[{
   RowBox[{"result", " ", "=", " ", 
    RowBox[{"STToGinsh", "[", 
     RowBox[{
      RowBox[{"3", " ", 
       RowBox[{"Hlog", "[", 
        RowBox[{"2", ",", " ", 
         RowBox[{"{", 
          RowBox[{"0", ",", " ", "1"}], "}"}]}], "]"}]}], " ", "+", " ", 
      RowBox[{"mzv", "[", "3", "]"}]}], "]"}]}], "\n", "    ", 
   RowBox[{"(*", " ", 
    RowBox[{"Out", ":", " ", 
     RowBox[{
      RowBox[{"-", "6.20015"}], " ", "+", " ", 
      RowBox[{"6.53276", " ", "I"}]}]}], " ", "*)"}]}]}]], "Input",ExpressionU\
UID->"b98db5a1-52eb-4bf7-8bae-e74d522e71f5"]
}, Open  ]],


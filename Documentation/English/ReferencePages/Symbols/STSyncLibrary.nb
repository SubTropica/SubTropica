Cell[BoxData[GridBox[{
   {Cell[TextData[{
     StyleBox["STSyncLibrary[]", "TI"],
     " \[LineSeparator]downloads new and updated entries from the central \
SubTropica library. Only changed files are downloaded (incremental sync)."
    }], "TableText",ExpressionUUID->"ded81ddd-e372-4b0e-abbb-40b702cf6a5d"]},
   {Cell[TextData[{
     StyleBox["STSyncLibrary[\"DryRun\" -> True]", "TI"],

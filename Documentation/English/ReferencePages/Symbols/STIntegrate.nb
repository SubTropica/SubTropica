Cell["\<\
Evaluate a generic Euler integral with Mathematica-style limits:\
\>", "ExampleText",ExpressionUUID->"0c677a28-3c9b-417f-b9e1-e5190fe4adc9"],

Cell[BoxData[
 RowBox[{"STIntegrate", "[", "\n", "  ", 
  RowBox[{
   RowBox[{
    RowBox[{"x", "^", 
     RowBox[{"(", 
      RowBox[{
       RowBox[{"-", "1"}], "+", "eps"}], ")"}]}], " ", 
    RowBox[{
     RowBox[{"(", 
      RowBox[{"1", "+", "x"}], ")"}], "^", 
     RowBox[{"(", 
      RowBox[{
       RowBox[{"-", "1"}], "-", 
       RowBox[{"2", "eps"}]}], ")"}]}]}], ",", " ", 
   RowBox[{"{", 
    RowBox[{"x", ",", " ", "0", ",", " ", "Infinity"}], "}"}], ",", "\n", 
   "  ", 
   RowBox[{"\"\<Order\>\"", " ", "->", " ", "1"}]}], "]"}]], "Input",Expressio\
nUUID->"db4b0d6e-c8e5-411a-918c-b5821e8c3b19"],

Cell[BoxData[
 InterpretationBox[Cell[
  "\t", "ExampleDelimiter",ExpressionUUID->

Cell[CellGroupData[{

Cell["Exponents", "ExampleSubsection",ExpressionUUID->"50c6b4fd-c154-4e9e-a559-076fc9318e31"],

Cell["Squared propagators and numerator insertions:", "ExampleText",ExpressionUUID->"cd990b70-1475-48d2-a1f5-b920ab98c505"],

Cell[BoxData[
 RowBox[{"STIntegrate", "[", "\n", "  ", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{"l", "[", "1", "]"}], "^", "2"}], " ", "-", " ", 
      RowBox[{"m", "^", "2"}]}], ",", " ", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{
        RowBox[{"l", "[", "1", "]"}], "-", 
        RowBox[{"p", "[", "1", "]"}]}], ")"}], "^", "2"}], ",", " ", 
     RowBox[{"q", " ", 
      RowBox[{"l", "[", "1", "]"}]}]}], "}"}], ",", "\n", "  ", 
   RowBox[{"\"\<Exponents\>\"", " ", "->", " ", 
    RowBox[{"{", 
     RowBox[{"2", ",", " ", "1", ",", " ", 
      RowBox[{"-", "1"}]}], "}"}]}], ",", "\n", "  ", 
   RowBox[{"\"\<Substitutions\>\"", " ", "->", " ", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"M", "[", "1", "]"}], " ", "->", " ", 
      RowBox[{"Sqrt", "[", "s", "]"}]}], "}"}]}]}], "]"}]], "Input",Expression\
UUID->"8909a0f1-36e7-4c63-b6f4-767551b7e992"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Gauge", "ExampleSubsection",ExpressionUUID->"66aa99d8-9ef2-450f-8af5-ebdbc8152e96"],

Cell["Fix a specific gauge instead of scanning:", "ExampleText",ExpressionUUID->"16579790-476a-41bf-b455-2364ab775003"],

Cell[BoxData[
 RowBox[{"STIntegrate", "[", "\n", "  ", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{
      RowBox[{"l", "[", "1", "]"}], "^", "2"}], ",", " ", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{
        RowBox[{"l", "[", "1", "]"}], "-", 
        RowBox[{"p", "[", "1", "]"}]}], ")"}], "^", "2"}], ",", " ", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{
        RowBox[{"l", "[", "1", "]"}], "-", 
        RowBox[{"p", "[", "1", "]"}], "-", 
        RowBox[{"p", "[", "2", "]"}]}], ")"}], "^", "2"}]}], "}"}], ",", "\n",
    "  ", 
   RowBox[{"\"\<Substitutions\>\"", " ", "->", " ", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{
       RowBox[{"M", "[", "1", "]"}], " ", "->", " ", "0"}], ",", " ", 
      RowBox[{
       RowBox[{"M", "[", "2", "]"}], " ", "->", " ", "0"}], ",", " ", 
      RowBox[{
       RowBox[{"M", "[", "3", "]"}], " ", "->", " ", 
       RowBox[{"Sqrt", "[", "s", "]"}]}]}], "}"}]}], ",", "\n", "  ", 
   RowBox[{"\"\<Gauge\>\"", " ", "->", " ", 
    RowBox[{"{", 
     RowBox[{"x3", " ", "->", " ", "1"}], "}"}]}]}], "]"}]], "Input",Expressio\
nUUID->"97fc250d-0ced-4324-9d3e-1542aca805c8"]
}, Open  ]],

Cell[CellGroupData[{

Cell["StopAt and StartAt", "ExampleSubsection",ExpressionUUID->"2b2bceb7-93a1-4a18-b292-d5247987fc27"],

Cell["Pause the pipeline after building the integrand:", "ExampleText",ExpressionUUID->"d7bff514-a3cd-49a2-b7b9-d1221ec76ff4"],

Cell[BoxData[
 RowBox[{"result", " ", "=", " ", 
  RowBox[{"STIntegrate", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{
       RowBox[{"l", "[", "1", "]"}], "^", "2"}], ",", " ", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{
         RowBox[{"l", "[", "1", "]"}], "-", 
         RowBox[{"p", "[", "1", "]"}]}], ")"}], "^", "2"}]}], "}"}], ",", 
    "\n", "  ", 
    RowBox[{"\"\<Substitutions\>\"", " ", "->", " ", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"M", "[", "1", "]"}], " ", "->", " ", 
       RowBox[{"Sqrt", "[", "s", "]"}]}], "}"}]}], ",", "\n", "  ", 
    RowBox[{"\"\<StopAt\>\"", " ", "->", 
     " ", "\"\<AfterBuildingIntegrand\>\""}]}], "]"}]}]], "Input",ExpressionUU\
ID->"b6339b9c-39bb-49f4-9c23-46a34a8cd087"],

Cell["Resume from a checkpoint:", "ExampleText",ExpressionUUID->"560bcf47-afa0-4086-b955-1315d5fdcc2b"],

Cell[BoxData[
 RowBox[{"STIntegrate", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{
      RowBox[{"l", "[", "1", "]"}], "^", "2"}], ",", " ", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{
        RowBox[{"l", "[", "1", "]"}], "-", 
        RowBox[{"p", "[", "1", "]"}]}], ")"}], "^", "2"}]}], "}"}], ",", "\n",
    "  ", 
   RowBox[{"\"\<Substitutions\>\"", " ", "->", " ", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"M", "[", "1", "]"}], " ", "->", " ", 
      RowBox[{"Sqrt", "[", "s", "]"}]}], "}"}]}], ",", "\n", "  ", 
   RowBox[{"\"\<StartAt\>\"", " ", "->", " ", 
    RowBox[{"result", "[", "\"\<CheckpointID\>\"", "]"}]}]}], "]"}]], "Input",\
ExpressionUUID->"ca850663-3009-426c-8592-311e4b2a958a"]
}, Open  ]],

Cell[CellGroupData[{

Cell["SelectFaces", "ExampleSubsection",ExpressionUUID->"2f885f12-b800-4a01-9aa3-17c8d972238c"],

Cell["Integrate only specific tropical faces:", "ExampleText",ExpressionUUID->"11883291-bed9-4801-ad2a-57a97e968592"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{"First", " ", "obtain", " ", "a", " ", "checkpoint"}], " ", "*)"}],
   "\n", 
  RowBox[{
   RowBox[{"stage", " ", "=", " ", 
    RowBox[{"STIntegrate", "[", 
     RowBox[{"diag", ",", " ", 
      RowBox[{"\"\<StopAt\>\"", " ", "->", 
       " ", "\"\<AfterLinearOrder\>\""}]}], "]"}]}], "\n", 
   RowBox[{"(*", " ", 
    RowBox[{
    "Integrate", " ", "faces", " ", "1", " ", "and", " ", "4", " ", "only"}], 
    " ", "*)"}], "\n", 
   RowBox[{"STIntegrate", "[", 
    RowBox[{"diag", ",", " ", 
     RowBox[{"\"\<StartAt\>\"", " ", "->", " ", 
      RowBox[{"stage", "[", "\"\<CheckpointID\>\"", "]"}]}], ",", "\n", "  ", 
     
     RowBox[{"\"\<SelectFaces\>\"", " ", "->", " ", 
      RowBox[{"{", 
       RowBox[{"1", ",", " ", "4"}], "}"}]}]}], "]"}]}]}]], "Input",Expression\
UUID->"f02c719d-0521-4dc0-80d3-c67b0e0d7f9e"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["Applications", "ExampleSection",ExpressionUUID->"9efbdbe0-b51b-4830-8e37-00c1943662fc"],

Cell["\<\
Compute the one-loop contribution to the electron anomalous magnetic moment. \
The triangle diagram has two massive propagators (electron mass m) and one \
massless propagator (photon), with a numerator from the QED vertex:\
\>", "ExampleText",ExpressionUUID->"2c090b18-4606-4103-a7e7-6bb974e1cd30"],

Cell[BoxData[
 RowBox[{"STIntegrate", "[", "\n", "  ", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{
      RowBox[{"(", 
       RowBox[{
        RowBox[{"l", "[", "1", "]"}], " ", "-", " ", 
        RowBox[{"p", "[", "2", "]"}]}], ")"}], "^", "2"}], ",", "\n", "   ", 
     RowBox[{
      RowBox[{"-", 
       RowBox[{"m", "^", "2"}]}], " ", "+", " ", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{
         RowBox[{"-", 
          RowBox[{"l", "[", "1", "]"}]}], " ", "+", " ", 
         RowBox[{"p", "[", "1", "]"}], " ", "+", " ", 
         RowBox[{"p", "[", "2", "]"}]}], ")"}], "^", "2"}]}], ",", "\n", 
     "   ", 
     RowBox[{
      RowBox[{"-", 
       RowBox[{"m", "^", "2"}]}], " ", "+", " ", 
      RowBox[{
       RowBox[{"l", "[", "1", "]"}], "^", "2"}]}], ",", "\n", "   ", 
     RowBox[{"q", " ", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{"l", "[", "1", "]"}], " ", "-", " ", 
        RowBox[{"p", "[", "2", "]"}]}], ")"}]}]}], "}"}], ",", "\n", "  ", 
   RowBox[{"\"\<Exponents\>\"", " ", "->", " ", 
    RowBox[{"{", 
     RowBox[{"1", ",", " ", "1", ",", " ", "1", ",", " ", 
      RowBox[{"-", "1"}]}], "}"}]}], ",", "\n", "  ", 
   RowBox[{"\"\<Substitutions\>\"", " ", "->", " ", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{
       RowBox[{"M", "[", "1", "]"}], " ", "->", " ", "m"}], ",", " ", 
      RowBox[{
       RowBox[{"M", "[", "2", "]"}], " ", "->", " ", "m"}], ",", " ", 
      RowBox[{
       RowBox[{"M", "[", "3", "]"}], " ", "->", " ", "0"}]}], "}"}]}], ",", 
   "\n", "  ", 
   RowBox[{"\"\<CleanOutput\>\"", " ", "->", " ", "True"}]}], "]"}]], "Input",\
ExpressionUUID->"b39e3742-32e8-41da-9048-fa9882cd42c3"]
}, Open  ]]
}, Open  ]],


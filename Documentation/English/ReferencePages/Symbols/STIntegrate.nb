Cell["\<\
Evaluate a generic Euler integral with Mathematica-style limits:\
\>", "ExampleText",ExpressionUUID->"d2b13bb2-966b-4474-bf21-29933ba6089d"],

Cell[BoxData[
 RowBox[{"STIntegrate", "[", "\n", "  ", 
  RowBox[{
   RowBox[{
    RowBox[{"x", "^", 
     RowBox[{"(", 
      RowBox[{
       RowBox[{"-", "1"}], "+", "eps"}], ")"}]}], " ", 
    RowBox[{
     RowBox[{"(", 
      RowBox[{"1", "+", "x"}], ")"}], "^", 
     RowBox[{"(", 
      RowBox[{
       RowBox[{"-", "1"}], "-", 
       RowBox[{"2", "eps"}]}], ")"}]}]}], ",", " ", 
   RowBox[{"{", 
    RowBox[{"x", ",", " ", "0", ",", " ", "Infinity"}], "}"}], ",", "\n", 
   "  ", 
   RowBox[{"\"\<Order\>\"", " ", "->", " ", "1"}]}], "]"}]], "Input",Expressio\
nUUID->"ce43ee2c-4112-4142-b45b-0fe5de12e2af"],

Cell[BoxData[
 InterpretationBox[Cell[
  "\t", "ExampleDelimiter",ExpressionUUID->

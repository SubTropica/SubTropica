Cell[CellGroupData[{

Cell["Exponents", "ExampleSubsection",ExpressionUUID->"47e7126a-3596-4e8f-8b55-6cd79b416e2c"],

Cell["Squared propagators and numerator insertions:", "ExampleText",ExpressionUUID->"c290c71e-c672-43f1-a031-4bbac5975955"],

Cell[BoxData[
 RowBox[{"STIntegrate", "[", "\n", "  ", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{"l", "[", "1", "]"}], "^", "2"}], " ", "-", " ", 
      RowBox[{"m", "^", "2"}]}], ",", " ", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{
        RowBox[{"l", "[", "1", "]"}], "-", 
        RowBox[{"p", "[", "1", "]"}]}], ")"}], "^", "2"}], ",", " ", 
     RowBox[{"q", " ", 
      RowBox[{"l", "[", "1", "]"}]}]}], "}"}], ",", "\n", "  ", 
   RowBox[{"\"\<Exponents\>\"", " ", "->", " ", 
    RowBox[{"{", 
     RowBox[{"2", ",", " ", "1", ",", " ", 
      RowBox[{"-", "1"}]}], "}"}]}], ",", "\n", "  ", 
   RowBox[{"\"\<Substitutions\>\"", " ", "->", " ", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"M", "[", "1", "]"}], " ", "->", " ", 
      RowBox[{"Sqrt", "[", "s", "]"}]}], "}"}]}]}], "]"}]], "Input",Expression\
UUID->"70b51d5d-871e-4ebd-9738-73d140d0ea13"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Gauge", "ExampleSubsection",ExpressionUUID->"63e5a1f4-89c0-41a0-9d13-b730d0228a06"],

Cell["Fix a specific gauge instead of scanning:", "ExampleText",ExpressionUUID->"ac8ef82d-5a1a-48b3-bad9-107e93f8d03c"],

Cell[BoxData[
 RowBox[{"STIntegrate", "[", "\n", "  ", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{
      RowBox[{"l", "[", "1", "]"}], "^", "2"}], ",", " ", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{
        RowBox[{"l", "[", "1", "]"}], "-", 
        RowBox[{"p", "[", "1", "]"}]}], ")"}], "^", "2"}], ",", " ", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{
        RowBox[{"l", "[", "1", "]"}], "-", 
        RowBox[{"p", "[", "1", "]"}], "-", 
        RowBox[{"p", "[", "2", "]"}]}], ")"}], "^", "2"}]}], "}"}], ",", "\n",
    "  ", 
   RowBox[{"\"\<Substitutions\>\"", " ", "->", " ", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{
       RowBox[{"M", "[", "1", "]"}], " ", "->", " ", "0"}], ",", " ", 
      RowBox[{
       RowBox[{"M", "[", "2", "]"}], " ", "->", " ", "0"}], ",", " ", 
      RowBox[{
       RowBox[{"M", "[", "3", "]"}], " ", "->", " ", 
       RowBox[{"Sqrt", "[", "s", "]"}]}]}], "}"}]}], ",", "\n", "  ", 
   RowBox[{"\"\<Gauge\>\"", " ", "->", " ", 
    RowBox[{"{", 
     RowBox[{"x3", " ", "->", " ", "1"}], "}"}]}]}], "]"}]], "Input",Expressio\
nUUID->"4dede35d-96bb-449a-999f-b78637b39183"]
}, Open  ]],

Cell[CellGroupData[{

Cell["StopAt and StartAt", "ExampleSubsection",ExpressionUUID->"3923dcfa-989f-4860-96a6-23e244f25b91"],

Cell["Pause the pipeline after building the integrand:", "ExampleText",ExpressionUUID->"f3631416-5a51-444b-8173-95a66cc5842e"],

Cell[BoxData[
 RowBox[{"result", " ", "=", " ", 
  RowBox[{"STIntegrate", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{
       RowBox[{"l", "[", "1", "]"}], "^", "2"}], ",", " ", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{
         RowBox[{"l", "[", "1", "]"}], "-", 
         RowBox[{"p", "[", "1", "]"}]}], ")"}], "^", "2"}]}], "}"}], ",", 
    "\n", "  ", 
    RowBox[{"\"\<Substitutions\>\"", " ", "->", " ", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"M", "[", "1", "]"}], " ", "->", " ", 
       RowBox[{"Sqrt", "[", "s", "]"}]}], "}"}]}], ",", "\n", "  ", 
    RowBox[{"\"\<StopAt\>\"", " ", "->", 
     " ", "\"\<AfterBuildingIntegrand\>\""}]}], "]"}]}]], "Input",ExpressionUU\
ID->"a5c7ab17-a0c5-466b-adcb-143e8a0ec052"],

Cell["Resume from a checkpoint:", "ExampleText",ExpressionUUID->"e73e659b-d124-4ba6-8b3a-0348579c38a2"],

Cell[BoxData[
 RowBox[{"STIntegrate", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{
      RowBox[{"l", "[", "1", "]"}], "^", "2"}], ",", " ", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{
        RowBox[{"l", "[", "1", "]"}], "-", 
        RowBox[{"p", "[", "1", "]"}]}], ")"}], "^", "2"}]}], "}"}], ",", "\n",
    "  ", 
   RowBox[{"\"\<Substitutions\>\"", " ", "->", " ", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"M", "[", "1", "]"}], " ", "->", " ", 
      RowBox[{"Sqrt", "[", "s", "]"}]}], "}"}]}], ",", "\n", "  ", 
   RowBox[{"\"\<StartAt\>\"", " ", "->", " ", 
    RowBox[{"result", "[", "\"\<CheckpointID\>\"", "]"}]}]}], "]"}]], "Input",\
ExpressionUUID->"f72e7b62-1c78-4621-992e-1b8be8ebcf5b"]
}, Open  ]],

Cell[CellGroupData[{

Cell["SelectFaces", "ExampleSubsection",ExpressionUUID->"30d2c6df-10fa-42c0-947f-9f0434771cff"],

Cell["Integrate only specific tropical faces:", "ExampleText",ExpressionUUID->"1732979d-0031-497b-a6a0-b2a87b93bda5"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{"First", " ", "obtain", " ", "a", " ", "checkpoint"}], " ", "*)"}],
   "\n", 
  RowBox[{
   RowBox[{"stage", " ", "=", " ", 
    RowBox[{"STIntegrate", "[", 
     RowBox[{"diag", ",", " ", 
      RowBox[{"\"\<StopAt\>\"", " ", "->", 
       " ", "\"\<AfterLinearOrder\>\""}]}], "]"}]}], "\n", 
   RowBox[{"(*", " ", 
    RowBox[{
    "Integrate", " ", "faces", " ", "1", " ", "and", " ", "4", " ", "only"}], 
    " ", "*)"}], "\n", 
   RowBox[{"STIntegrate", "[", 
    RowBox[{"diag", ",", " ", 
     RowBox[{"\"\<StartAt\>\"", " ", "->", " ", 
      RowBox[{"stage", "[", "\"\<CheckpointID\>\"", "]"}]}], ",", "\n", "  ", 
     
     RowBox[{"\"\<SelectFaces\>\"", " ", "->", " ", 
      RowBox[{"{", 
       RowBox[{"1", ",", " ", "4"}], "}"}]}]}], "]"}]}]}]], "Input",Expression\
UUID->"8c721306-ffb5-40fa-9737-4de29ed57708"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["Applications", "ExampleSection",ExpressionUUID->"6cff64e8-de53-4e96-8826-7f2919cbecf8"],

Cell["\<\
Compute the one-loop contribution to the electron anomalous magnetic moment. \
The triangle diagram has two massive propagators (electron mass m) and one \
massless propagator (photon), with a numerator from the QED vertex:\
\>", "ExampleText",ExpressionUUID->"abf66ac0-d776-41b4-b25d-e8d75e6ce341"],

Cell[BoxData[
 RowBox[{"STIntegrate", "[", "\n", "  ", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{
      RowBox[{"(", 
       RowBox[{
        RowBox[{"l", "[", "1", "]"}], " ", "-", " ", 
        RowBox[{"p", "[", "2", "]"}]}], ")"}], "^", "2"}], ",", "\n", "   ", 
     RowBox[{
      RowBox[{"-", 
       RowBox[{"m", "^", "2"}]}], " ", "+", " ", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{
         RowBox[{"-", 
          RowBox[{"l", "[", "1", "]"}]}], " ", "+", " ", 
         RowBox[{"p", "[", "1", "]"}], " ", "+", " ", 
         RowBox[{"p", "[", "2", "]"}]}], ")"}], "^", "2"}]}], ",", "\n", 
     "   ", 
     RowBox[{
      RowBox[{"-", 
       RowBox[{"m", "^", "2"}]}], " ", "+", " ", 
      RowBox[{
       RowBox[{"l", "[", "1", "]"}], "^", "2"}]}], ",", "\n", "   ", 
     RowBox[{"q", " ", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{"l", "[", "1", "]"}], " ", "-", " ", 
        RowBox[{"p", "[", "2", "]"}]}], ")"}]}]}], "}"}], ",", "\n", "  ", 
   RowBox[{"\"\<Exponents\>\"", " ", "->", " ", 
    RowBox[{"{", 
     RowBox[{"1", ",", " ", "1", ",", " ", "1", ",", " ", 
      RowBox[{"-", "1"}]}], "}"}]}], ",", "\n", "  ", 
   RowBox[{"\"\<Substitutions\>\"", " ", "->", " ", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{
       RowBox[{"M", "[", "1", "]"}], " ", "->", " ", "m"}], ",", " ", 
      RowBox[{
       RowBox[{"M", "[", "2", "]"}], " ", "->", " ", "m"}], ",", " ", 
      RowBox[{
       RowBox[{"M", "[", "3", "]"}], " ", "->", " ", "0"}]}], "}"}]}], ",", 
   "\n", "  ", 
   RowBox[{"\"\<CleanOutput\>\"", " ", "->", " ", "True"}]}], "]"}]], "Input",\
ExpressionUUID->"0324482d-1230-473c-9021-54cf7d2c33d7"]
}, Open  ]]
}, Open  ]],


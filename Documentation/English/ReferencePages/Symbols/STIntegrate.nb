Cell["Evaluate a massive triangle from a graph topology:", "ExampleText",ExpressionUUID->"d5da5c7e-520f-4813-b064-6055a78830bd"],

Cell[BoxData[
 RowBox[{"STIntegrate", "[", "\n", "  ", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"1", ",", "2"}], "}"}], ",", "0"}], "}"}], ",", " ", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"2", ",", "3"}], "}"}], ",", "0"}], "}"}], ",", " ", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"1", ",", "3"}], "}"}], ",", "0"}], "}"}]}], "}"}], ",", 
     "\n", "   ", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"1", ",", " ", "M1"}], "}"}], ",", " ", 
       RowBox[{"{", 
        RowBox[{"2", ",", " ", "M2"}], "}"}], ",", " ", 
       RowBox[{"{", 
        RowBox[{"3", ",", " ", "M3"}], "}"}]}], "}"}]}], "}"}], ",", "\n", 
   "  ", 
   RowBox[{"\"\<Substitutions\>\"", " ", "->", " ", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"MM1", " ", "->", " ", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{"1", "-", "z"}], ")"}], 
        RowBox[{"(", 
         RowBox[{"1", "-", "zb"}], ")"}]}]}], ",", " ", 
      RowBox[{"MM2", " ", "->", " ", 
       RowBox[{"z", " ", "zb"}]}], ",", " ", 
      RowBox[{"MM3", " ", "->", " ", "1"}]}], "}"}]}]}], "]"}]], "Input",Expre\
ssionUUID->"8e55a31b-4093-42a0-bd67-2cabcfbcd39b"],


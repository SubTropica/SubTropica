Cell["\<\
Evaluate a generic Euler integral with Mathematica-style limits:\
\>", "ExampleText",ExpressionUUID->"f75e0975-fe5d-40c4-a1f6-d37e5fdba97b"],

Cell[BoxData[
 RowBox[{"STIntegrate", "[", "\n", "  ", 
  RowBox[{
   RowBox[{
    RowBox[{"x", "^", 
     RowBox[{"(", 
      RowBox[{
       RowBox[{"-", "1"}], "+", "eps"}], ")"}]}], " ", 
    RowBox[{
     RowBox[{"(", 
      RowBox[{"1", "+", "x"}], ")"}], "^", 
     RowBox[{"(", 
      RowBox[{
       RowBox[{"-", "1"}], "-", 
       RowBox[{"2", "eps"}]}], ")"}]}]}], ",", " ", 
   RowBox[{"{", 
    RowBox[{"x", ",", " ", "0", ",", " ", "Infinity"}], "}"}], ",", "\n", 
   "  ", 
   RowBox[{"\"\<Order\>\"", " ", "->", " ", "1"}]}], "]"}]], "Input",Expressio\
nUUID->"d23cd99f-3736-412a-a5ed-0eaab6929438"],

Cell[BoxData[
 InterpretationBox[Cell[
  "\t", "ExampleDelimiter",ExpressionUUID->
   "35a1becb-77d7-4e84-94ed-7c1bc832f1bb"],
  $Line = 0]], "ExampleDelimiter",ExpressionUUID->"db1e5be0-8679-4274-860f-\
4385aec99eb4"],

Cell["Include a numerator insertion using negative exponents:", "ExampleText",ExpressionUUID->"791ae058-fc3d-4d61-9763-7aec8b74fabb"],

Cell[BoxData[
 RowBox[{"STIntegrate", "[", "\n", "  ", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{"l", "[", "1", "]"}], "^", "2"}], " ", "-", " ", "mm"}], ",", 
     " ", 
     RowBox[{
      RowBox[{"q", "[", "1", "]"}], " ", 
      RowBox[{"l", "[", "1", "]"}]}], ",", " ", 
     RowBox[{
      RowBox[{"q", "[", "2", "]"}], " ", 
      RowBox[{"l", "[", "1", "]"}]}]}], "}"}], ",", "\n", "  ", 
   RowBox[{"\"\<Exponents\>\"", " ", "->", " ", 
    RowBox[{"{", 
     RowBox[{"2", ",", " ", 
      RowBox[{"-", "1"}], ",", " ", 
      RowBox[{"-", "1"}]}], "}"}]}]}], "]"}]], "Input",ExpressionUUID->\
"651e2609-758f-4d51-bc41-efd2f59f1bee"]
}, Open  ]],


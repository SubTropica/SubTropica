Cell[CellGroupData[{

Cell["Exponents", "ExampleSubsection",ExpressionUUID->"280bc37f-1554-40ad-a6af-e895cf540fbe"],

Cell["Squared propagators and numerator insertions:", "ExampleText",ExpressionUUID->"766217e8-6695-48c1-9d0f-bf12dccdb55f"],

Cell[BoxData[
 RowBox[{"STIntegrate", "[", "\n", "  ", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{"l", "[", "1", "]"}], "^", "2"}], " ", "-", " ", 
      RowBox[{"m", "^", "2"}]}], ",", " ", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{
        RowBox[{"l", "[", "1", "]"}], "-", 
        RowBox[{"p", "[", "1", "]"}]}], ")"}], "^", "2"}], ",", " ", 
     RowBox[{"q", " ", 
      RowBox[{"l", "[", "1", "]"}]}]}], "}"}], ",", "\n", "  ", 
   RowBox[{"\"\<Exponents\>\"", " ", "->", " ", 
    RowBox[{"{", 
     RowBox[{"2", ",", " ", "1", ",", " ", 
      RowBox[{"-", "1"}]}], "}"}]}], ",", "\n", "  ", 
   RowBox[{"\"\<Substitutions\>\"", " ", "->", " ", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"M", "[", "1", "]"}], " ", "->", " ", 
      RowBox[{"Sqrt", "[", "s", "]"}]}], "}"}]}]}], "]"}]], "Input",Expression\
UUID->"fb5e0772-62ce-49f7-bbfe-316ed697aa84"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Gauge", "ExampleSubsection",ExpressionUUID->"6bd6a226-d80e-432e-b5e5-5fda7b5d3edb"],

Cell["Fix a specific gauge instead of scanning:", "ExampleText",ExpressionUUID->"21603926-1d1e-4411-b127-3f23af7bc0a2"],

Cell[BoxData[
 RowBox[{"STIntegrate", "[", "\n", "  ", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{
      RowBox[{"l", "[", "1", "]"}], "^", "2"}], ",", " ", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{
        RowBox[{"l", "[", "1", "]"}], "-", 
        RowBox[{"p", "[", "1", "]"}]}], ")"}], "^", "2"}], ",", " ", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{
        RowBox[{"l", "[", "1", "]"}], "-", 
        RowBox[{"p", "[", "1", "]"}], "-", 
        RowBox[{"p", "[", "2", "]"}]}], ")"}], "^", "2"}]}], "}"}], ",", "\n",
    "  ", 
   RowBox[{"\"\<Substitutions\>\"", " ", "->", " ", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{
       RowBox[{"M", "[", "1", "]"}], " ", "->", " ", "0"}], ",", " ", 
      RowBox[{
       RowBox[{"M", "[", "2", "]"}], " ", "->", " ", "0"}], ",", " ", 
      RowBox[{
       RowBox[{"M", "[", "3", "]"}], " ", "->", " ", 
       RowBox[{"Sqrt", "[", "s", "]"}]}]}], "}"}]}], ",", "\n", "  ", 
   RowBox[{"\"\<Gauge\>\"", " ", "->", " ", 
    RowBox[{"{", 
     RowBox[{"x3", " ", "->", " ", "1"}], "}"}]}]}], "]"}]], "Input",Expressio\
nUUID->"bf2a6b02-e38a-4c91-89fc-7af83f1d32df"]
}, Open  ]],

Cell[CellGroupData[{

Cell["StopAt and StartAt", "ExampleSubsection",ExpressionUUID->"bd892ee6-66eb-4218-9c96-6f7a40472eba"],

Cell["Pause the pipeline after building the integrand:", "ExampleText",ExpressionUUID->"b2e74a2d-6326-4949-a8db-281cf4696181"],

Cell[BoxData[
 RowBox[{"result", " ", "=", " ", 
  RowBox[{"STIntegrate", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{
       RowBox[{"l", "[", "1", "]"}], "^", "2"}], ",", " ", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{
         RowBox[{"l", "[", "1", "]"}], "-", 
         RowBox[{"p", "[", "1", "]"}]}], ")"}], "^", "2"}]}], "}"}], ",", 
    "\n", "  ", 
    RowBox[{"\"\<Substitutions\>\"", " ", "->", " ", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"M", "[", "1", "]"}], " ", "->", " ", 
       RowBox[{"Sqrt", "[", "s", "]"}]}], "}"}]}], ",", "\n", "  ", 
    RowBox[{"\"\<StopAt\>\"", " ", "->", 
     " ", "\"\<AfterBuildingIntegrand\>\""}]}], "]"}]}]], "Input",ExpressionUU\
ID->"1cb24d9b-655e-4a3f-a7a6-87724ff48dae"],

Cell["Resume from a checkpoint:", "ExampleText",ExpressionUUID->"89443287-aadf-46dd-9772-0a8e7be1a963"],

Cell[BoxData[
 RowBox[{"STIntegrate", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{
      RowBox[{"l", "[", "1", "]"}], "^", "2"}], ",", " ", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{
        RowBox[{"l", "[", "1", "]"}], "-", 
        RowBox[{"p", "[", "1", "]"}]}], ")"}], "^", "2"}]}], "}"}], ",", "\n",
    "  ", 
   RowBox[{"\"\<Substitutions\>\"", " ", "->", " ", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"M", "[", "1", "]"}], " ", "->", " ", 
      RowBox[{"Sqrt", "[", "s", "]"}]}], "}"}]}], ",", "\n", "  ", 
   RowBox[{"\"\<StartAt\>\"", " ", "->", " ", 
    RowBox[{"result", "[", "\"\<CheckpointID\>\"", "]"}]}]}], "]"}]], "Input",\
ExpressionUUID->"ac74a466-e586-4dc8-b988-c0621667c23f"]
}, Open  ]],

Cell[CellGroupData[{

Cell["SelectFaces", "ExampleSubsection",ExpressionUUID->"fd456cdd-1375-4fb0-abb9-005e4e05a2fd"],

Cell["Integrate only specific tropical faces:", "ExampleText",ExpressionUUID->"682ca62e-c9b2-434e-a220-4cdf87e93fcd"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{"First", " ", "obtain", " ", "a", " ", "checkpoint"}], " ", "*)"}],
   "\n", 
  RowBox[{
   RowBox[{"stage", " ", "=", " ", 
    RowBox[{"STIntegrate", "[", 
     RowBox[{"diag", ",", " ", 
      RowBox[{"\"\<StopAt\>\"", " ", "->", 
       " ", "\"\<AfterLinearOrder\>\""}]}], "]"}]}], "\n", 
   RowBox[{"(*", " ", 
    RowBox[{
    "Integrate", " ", "faces", " ", "1", " ", "and", " ", "4", " ", "only"}], 
    " ", "*)"}], "\n", 
   RowBox[{"STIntegrate", "[", 
    RowBox[{"diag", ",", " ", 
     RowBox[{"\"\<StartAt\>\"", " ", "->", " ", 
      RowBox[{"stage", "[", "\"\<CheckpointID\>\"", "]"}]}], ",", "\n", "  ", 
     
     RowBox[{"\"\<SelectFaces\>\"", " ", "->", " ", 
      RowBox[{"{", 
       RowBox[{"1", ",", " ", "4"}], "}"}]}]}], "]"}]}]}]], "Input",Expression\
UUID->"b0f98443-9d1d-4d4d-941c-f5f42ef79f45"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["Applications", "ExampleSection",ExpressionUUID->"6b093539-e0c9-46e3-8d0e-7b547a00fd0e"],

Cell["\<\
Compute the one-loop contribution to the electron anomalous magnetic moment. \
The triangle diagram has two massive propagators (electron mass m) and one \
massless propagator (photon), with a numerator from the QED vertex:\
\>", "ExampleText",ExpressionUUID->"3c9e6814-c3a2-4b60-981b-6207f7572608"],

Cell[BoxData[
 RowBox[{"STIntegrate", "[", "\n", "  ", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{
      RowBox[{"(", 
       RowBox[{
        RowBox[{"l", "[", "1", "]"}], " ", "-", " ", 
        RowBox[{"p", "[", "2", "]"}]}], ")"}], "^", "2"}], ",", "\n", "   ", 
     RowBox[{
      RowBox[{"-", 
       RowBox[{"m", "^", "2"}]}], " ", "+", " ", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{
         RowBox[{"-", 
          RowBox[{"l", "[", "1", "]"}]}], " ", "+", " ", 
         RowBox[{"p", "[", "1", "]"}], " ", "+", " ", 
         RowBox[{"p", "[", "2", "]"}]}], ")"}], "^", "2"}]}], ",", "\n", 
     "   ", 
     RowBox[{
      RowBox[{"-", 
       RowBox[{"m", "^", "2"}]}], " ", "+", " ", 
      RowBox[{
       RowBox[{"l", "[", "1", "]"}], "^", "2"}]}], ",", "\n", "   ", 
     RowBox[{"q", " ", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{"l", "[", "1", "]"}], " ", "-", " ", 
        RowBox[{"p", "[", "2", "]"}]}], ")"}]}]}], "}"}], ",", "\n", "  ", 
   RowBox[{"\"\<Exponents\>\"", " ", "->", " ", 
    RowBox[{"{", 
     RowBox[{"1", ",", " ", "1", ",", " ", "1", ",", " ", 
      RowBox[{"-", "1"}]}], "}"}]}], ",", "\n", "  ", 
   RowBox[{"\"\<Substitutions\>\"", " ", "->", " ", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{
       RowBox[{"M", "[", "1", "]"}], " ", "->", " ", "m"}], ",", " ", 
      RowBox[{
       RowBox[{"M", "[", "2", "]"}], " ", "->", " ", "m"}], ",", " ", 
      RowBox[{
       RowBox[{"M", "[", "3", "]"}], " ", "->", " ", "0"}]}], "}"}]}], ",", 
   "\n", "  ", 
   RowBox[{"\"\<CleanOutput\>\"", " ", "->", " ", "True"}]}], "]"}]], "Input",\
ExpressionUUID->"6817dc1d-c274-401c-81e0-99a504b1c867"]
}, Open  ]]
}, Open  ]],


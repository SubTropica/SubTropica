Cell["Scope", "ExampleSection",ExpressionUUID->"a8a9a2fb-230f-45a1-8feb-2a198c2358f4"],

Cell["\<\
Linearized (eikonal) propagators are supported alongside quadratic ones:\
\>", "ExampleText",ExpressionUUID->"1ed8f186-65c7-4ad6-b529-83d585a7d2e7"],

Cell[BoxData[
 RowBox[{"STIntegrate", "[", "\n", "  ", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{
      RowBox[{"k", "[", "1", "]"}], "^", "2"}], ",", " ", 
     RowBox[{
      RowBox[{"k", "[", "2", "]"}], "^", "2"}], ",", " ", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{
        RowBox[{"k", "[", "1", "]"}], "+", 
        RowBox[{"k", "[", "2", "]"}]}], ")"}], "^", "2"}], ",", " ", 
     RowBox[{
      RowBox[{
       RowBox[{"v", "[", "1", "]"}], " ", 
       RowBox[{"k", "[", "1", "]"}]}], "-", "1"}], ",", " ", 
     RowBox[{
      RowBox[{
       RowBox[{"v", "[", "2", "]"}], " ", 
       RowBox[{"k", "[", "2", "]"}]}], "-", "1"}]}], "}"}], ",", "\n", "  ", 
   RowBox[{"\"\<LoopMomenta\>\"", " ", "->", " ", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"k", "[", "1", "]"}], ",", " ", 
      RowBox[{"k", "[", "2", "]"}]}], "}"}]}], ",", "\n", "  ", 
   RowBox[{"\"\<Substitutions\>\"", " ", "->", " ", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{"v", "[", "1", "]"}], "^", "2"}], " ", "->", " ", "1"}], ",", 
      " ", 
      RowBox[{
       RowBox[{
        RowBox[{"v", "[", "2", "]"}], "^", "2"}], " ", "->", " ", "1"}]}], 
     "}"}]}]}], "]"}]], "Input",ExpressionUUID->"ca11e910-b177-4a6c-b4fc-\
109047d67369"]
}, Open  ]],


a7859b8408f8"],

Cell["Include a numerator insertion using negative exponents:", "ExampleText",ExpressionUUID->"c45ec350-9c29-4e6d-91b3-4f77fcf2b5b0"],

Cell[BoxData[
 RowBox[{"STIntegrate", "[", "\n", "  ", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{"l", "[", "1", "]"}], "^", "2"}], " ", "-", " ", "mm"}], ",", 
     " ", 
     RowBox[{
      RowBox[{"q", "[", "1", "]"}], " ", 
      RowBox[{"l", "[", "1", "]"}]}], ",", " ", 
     RowBox[{
      RowBox[{"q", "[", "2", "]"}], " ", 
      RowBox[{"l", "[", "1", "]"}]}]}], "}"}], ",", "\n", "  ", 
   RowBox[{"\"\<Exponents\>\"", " ", "->", " ", 
    RowBox[{"{", 
     RowBox[{"2", ",", " ", 
      RowBox[{"-", "1"}], ",", " ", 
      RowBox[{"-", "1"}]}], "}"}]}]}], "]"}]], "Input",ExpressionUUID->\
"4cd4ef54-fe4b-4b4a-baef-16d4be7fbdac"]
}, Open  ]],


Cell["Evaluate a massive triangle from a graph topology:", "ExampleText",ExpressionUUID->"24d696d8-119f-4dd9-9eb7-04240f2cadaf"],

Cell[BoxData[
 RowBox[{"STIntegrate", "[", "\n", "  ", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"1", ",", "2"}], "}"}], ",", "0"}], "}"}], ",", " ", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"2", ",", "3"}], "}"}], ",", "0"}], "}"}], ",", " ", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"1", ",", "3"}], "}"}], ",", "0"}], "}"}]}], "}"}], ",", 
     "\n", "   ", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"1", ",", " ", "M1"}], "}"}], ",", " ", 
       RowBox[{"{", 
        RowBox[{"2", ",", " ", "M2"}], "}"}], ",", " ", 
       RowBox[{"{", 
        RowBox[{"3", ",", " ", "M3"}], "}"}]}], "}"}]}], "}"}], ",", "\n", 
   "  ", 
   RowBox[{"\"\<Substitutions\>\"", " ", "->", " ", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"MM1", " ", "->", " ", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{"1", "-", "z"}], ")"}], 
        RowBox[{"(", 
         RowBox[{"1", "-", "zb"}], ")"}]}]}], ",", " ", 
      RowBox[{"MM2", " ", "->", " ", 
       RowBox[{"z", " ", "zb"}]}], ",", " ", 
      RowBox[{"MM3", " ", "->", " ", "1"}]}], "}"}]}]}], "]"}]], "Input",Expre\
ssionUUID->"c9484f8b-4dcf-4d18-b71f-6d2d2449cf91"],


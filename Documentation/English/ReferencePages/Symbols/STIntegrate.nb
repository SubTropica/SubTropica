Cell["Scope", "ExampleSection",ExpressionUUID->"751569df-92d0-4f60-9a92-12d296e112c9"],

Cell["\<\
Linearized (eikonal) propagators are supported alongside quadratic ones:\
\>", "ExampleText",ExpressionUUID->"bbe4eb31-b8ba-462e-b9bc-2bfad61faa6c"],

Cell[BoxData[
 RowBox[{"STIntegrate", "[", "\n", "  ", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{
      RowBox[{"k", "[", "1", "]"}], "^", "2"}], ",", " ", 
     RowBox[{
      RowBox[{"k", "[", "2", "]"}], "^", "2"}], ",", " ", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{
        RowBox[{"k", "[", "1", "]"}], "+", 
        RowBox[{"k", "[", "2", "]"}]}], ")"}], "^", "2"}], ",", " ", 
     RowBox[{
      RowBox[{
       RowBox[{"v", "[", "1", "]"}], " ", 
       RowBox[{"k", "[", "1", "]"}]}], "-", "1"}], ",", " ", 
     RowBox[{
      RowBox[{
       RowBox[{"v", "[", "2", "]"}], " ", 
       RowBox[{"k", "[", "2", "]"}]}], "-", "1"}]}], "}"}], ",", "\n", "  ", 
   RowBox[{"\"\<LoopMomenta\>\"", " ", "->", " ", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"k", "[", "1", "]"}], ",", " ", 
      RowBox[{"k", "[", "2", "]"}]}], "}"}]}], ",", "\n", "  ", 
   RowBox[{"\"\<Substitutions\>\"", " ", "->", " ", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{"v", "[", "1", "]"}], "^", "2"}], " ", "->", " ", "1"}], ",", 
      " ", 
      RowBox[{
       RowBox[{
        RowBox[{"v", "[", "2", "]"}], "^", "2"}], " ", "->", " ", "1"}]}], 
     "}"}]}]}], "]"}]], "Input",ExpressionUUID->"8531e0e1-f33a-4afe-9b41-\
b6896e39f5d3"]
}, Open  ]],


Cell["\<\
Evaluate a generic Euler integral with Mathematica-style limits:\
\>", "ExampleText",ExpressionUUID->"dcbc27b1-3991-4952-9bd1-d303a21ea78b"],

Cell[BoxData[
 RowBox[{"STIntegrate", "[", "\n", "  ", 
  RowBox[{
   RowBox[{
    RowBox[{"x", "^", 
     RowBox[{"(", 
      RowBox[{
       RowBox[{"-", "1"}], "+", "eps"}], ")"}]}], " ", 
    RowBox[{
     RowBox[{"(", 
      RowBox[{"1", "+", "x"}], ")"}], "^", 
     RowBox[{"(", 
      RowBox[{
       RowBox[{"-", "1"}], "-", 
       RowBox[{"2", "eps"}]}], ")"}]}]}], ",", " ", 
   RowBox[{"{", 
    RowBox[{"x", ",", " ", "0", ",", " ", "Infinity"}], "}"}], ",", "\n", 
   "  ", 
   RowBox[{"\"\<Order\>\"", " ", "->", " ", "1"}]}], "]"}]], "Input",Expressio\
nUUID->"9f80c358-f69e-452c-a556-b2587ba038f0"],

Cell[BoxData[
 InterpretationBox[Cell[
  "\t", "ExampleDelimiter",ExpressionUUID->
   "263072a2-7e2e-411e-b3d9-5e7abafa963f"],
  $Line = 0]], "ExampleDelimiter",ExpressionUUID->"86161f0e-8bf7-4416-b654-\
b859b2f26e61"],

Cell["Include a numerator insertion using negative exponents:", "ExampleText",ExpressionUUID->"dc6c9947-404a-4dec-9706-4e8b6c1cfd13"],

Cell[BoxData[
 RowBox[{"STIntegrate", "[", "\n", "  ", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{"l", "[", "1", "]"}], "^", "2"}], " ", "-", " ", "mm"}], ",", 
     " ", 
     RowBox[{
      RowBox[{"q", "[", "1", "]"}], " ", 
      RowBox[{"l", "[", "1", "]"}]}], ",", " ", 
     RowBox[{
      RowBox[{"q", "[", "2", "]"}], " ", 
      RowBox[{"l", "[", "1", "]"}]}]}], "}"}], ",", "\n", "  ", 
   RowBox[{"\"\<Exponents\>\"", " ", "->", " ", 
    RowBox[{"{", 
     RowBox[{"2", ",", " ", 
      RowBox[{"-", "1"}], ",", " ", 
      RowBox[{"-", "1"}]}], "}"}]}]}], "]"}]], "Input",ExpressionUUID->\
"5f73d400-330b-4e4d-854a-c6fdbfde380a"]
}, Open  ]],


Cell["Evaluate a massive triangle from a graph topology:", "ExampleText",ExpressionUUID->"1890dfd3-3bf5-4299-b134-5fd02c645467"],

Cell[BoxData[
 RowBox[{"STIntegrate", "[", "\n", "  ", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"1", ",", "2"}], "}"}], ",", "0"}], "}"}], ",", " ", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"2", ",", "3"}], "}"}], ",", "0"}], "}"}], ",", " ", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"1", ",", "3"}], "}"}], ",", "0"}], "}"}]}], "}"}], ",", 
     "\n", "   ", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"1", ",", " ", "M1"}], "}"}], ",", " ", 
       RowBox[{"{", 
        RowBox[{"2", ",", " ", "M2"}], "}"}], ",", " ", 
       RowBox[{"{", 
        RowBox[{"3", ",", " ", "M3"}], "}"}]}], "}"}]}], "}"}], ",", "\n", 
   "  ", 
   RowBox[{"\"\<Substitutions\>\"", " ", "->", " ", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"MM1", " ", "->", " ", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{"1", "-", "z"}], ")"}], 
        RowBox[{"(", 
         RowBox[{"1", "-", "zb"}], ")"}]}]}], ",", " ", 
      RowBox[{"MM2", " ", "->", " ", 
       RowBox[{"z", " ", "zb"}]}], ",", " ", 
      RowBox[{"MM3", " ", "->", " ", "1"}]}], "}"}]}]}], "]"}]], "Input",Expre\
ssionUUID->"7eb093ef-34f6-4f48-b3ac-6c7cef5b5f2e"],


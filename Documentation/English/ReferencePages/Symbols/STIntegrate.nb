Cell["Evaluate a one-loop massless bubble:", "ExampleText",ExpressionUUID->"329e0fa1-e650-4c2e-a560-e1d9f10a5180"],

Cell[BoxData[
 RowBox[{"STIntegrate", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{
      RowBox[{"l", "[", "1", "]"}], "^", "2"}], ",", " ", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{
        RowBox[{"l", "[", "1", "]"}], " ", "-", " ", 
        RowBox[{"p", "[", "1", "]"}]}], ")"}], "^", "2"}]}], "}"}], ",", " ", 
   "\n", "  ", 
   RowBox[{"\"\<Substitutions\>\"", " ", "->", " ", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"M", "[", "1", "]"}], " ", "->", " ", 
      RowBox[{"Sqrt", "[", "s", "]"}]}], "}"}]}], ",", " ", "\n", "  ", 
   RowBox[{"\"\<CleanOutput\>\"", " ", "->", " ", "True"}]}], "]"}]], "Input",\
ExpressionUUID->"f40ac770-6f66-4a6d-925b-e6fed1f60e93"],


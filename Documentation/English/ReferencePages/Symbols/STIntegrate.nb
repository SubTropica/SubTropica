Cell["Scope", "ExampleSection",ExpressionUUID->"e3445dab-970b-4e66-bc68-ae35dc53f2db"],

Cell["\<\
Linearized (eikonal) propagators are supported alongside quadratic ones:\
\>", "ExampleText",ExpressionUUID->"edee7653-4a0f-4dca-b617-4e159002e918"],

Cell[BoxData[
 RowBox[{"STIntegrate", "[", "\n", "  ", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{
      RowBox[{"k", "[", "1", "]"}], "^", "2"}], ",", " ", 
     RowBox[{
      RowBox[{"k", "[", "2", "]"}], "^", "2"}], ",", " ", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{
        RowBox[{"k", "[", "1", "]"}], "+", 
        RowBox[{"k", "[", "2", "]"}]}], ")"}], "^", "2"}], ",", " ", 
     RowBox[{
      RowBox[{
       RowBox[{"v", "[", "1", "]"}], " ", 
       RowBox[{"k", "[", "1", "]"}]}], "-", "1"}], ",", " ", 
     RowBox[{
      RowBox[{
       RowBox[{"v", "[", "2", "]"}], " ", 
       RowBox[{"k", "[", "2", "]"}]}], "-", "1"}]}], "}"}], ",", "\n", "  ", 
   RowBox[{"\"\<LoopMomenta\>\"", " ", "->", " ", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"k", "[", "1", "]"}], ",", " ", 
      RowBox[{"k", "[", "2", "]"}]}], "}"}]}], ",", "\n", "  ", 
   RowBox[{"\"\<Substitutions\>\"", " ", "->", " ", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{"v", "[", "1", "]"}], "^", "2"}], " ", "->", " ", "1"}], ",", 
      " ", 
      RowBox[{
       RowBox[{
        RowBox[{"v", "[", "2", "]"}], "^", "2"}], " ", "->", " ", "1"}]}], 
     "}"}]}]}], "]"}]], "Input",ExpressionUUID->"4028509e-7172-4500-bca6-\
4abe36d6335c"]
}, Open  ]],


Cell["Evaluate a one-loop massless bubble:", "ExampleText",ExpressionUUID->"c06a5702-a985-4a0d-8d93-396ecdc6e746"],

Cell[BoxData[
 RowBox[{"STIntegrate", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{
      RowBox[{"l", "[", "1", "]"}], "^", "2"}], ",", " ", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{
        RowBox[{"l", "[", "1", "]"}], " ", "-", " ", 
        RowBox[{"p", "[", "1", "]"}]}], ")"}], "^", "2"}]}], "}"}], ",", " ", 
   "\n", "  ", 
   RowBox[{"\"\<Substitutions\>\"", " ", "->", " ", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"M", "[", "1", "]"}], " ", "->", " ", 
      RowBox[{"Sqrt", "[", "s", "]"}]}], "}"}]}], ",", " ", "\n", "  ", 
   RowBox[{"\"\<CleanOutput\>\"", " ", "->", " ", "True"}]}], "]"}]], "Input",\
ExpressionUUID->"a3118421-2e9a-439b-aacb-77bf73603fc4"],


Notebook[{

Cell[CellGroupData[{
Cell["ZeroInfPeriodAsMpl", "ObjectName",ExpressionUUID->"77834a50-4a5e-491e-8650-bd64e584d138"],

Cell[BoxData[GridBox[{
   {Cell[TextData[{
     StyleBox["ZeroInfPeriodAsMpl", "TI"],
     " \[LineSeparator]While HyperIntica is the main (analytic) integration \
routine working under the hood of the STIntegrate function, it can also be \
used as a standalone function."
    }], "TableText",ExpressionUUID->"4e239d38-001f-4d02-b9ab-2542deabd13c"]}
  },
  GridBoxAlignment->{"Columns" -> {{Left}}},
  GridBoxItemSize->{
   "Columns" -> {{Automatic}}, "Rows" -> {{Automatic}}}]], "Usage",
 CellID->1,ExpressionUUID->"21cb4337-23f7-4c0d-809d-f574a50d81ec"],

Cell["\<\
While HyperIntica is the main (analytic) integration routine working under \
the hood of the STIntegrate function, it can also be used as a standalone \
function. It evaluates iterated integrals \[Integral]_0^\[Infinity] \
\[Ellipsis] \[Integral]_0^\[Infinity] f\\, dx_1 \[Ellipsis] dx_n in  for \
expressions built from hyperlogarithms, polylogarithms, logarithms, and \
rational functions, returning results in terms of multi-zeta values and \
hyperlogarithms in the original integrand f parameters (if any). The syntax \
is: (see example below)\
\>", "Notes",ExpressionUUID->"ab53d724-4e6a-4b3b-abb3-8d2b5d248b32"],

Cell[BoxData[
 RowBox[{"HyperIntica", "[", 
  RowBox[{"integrand", ",", " ", "variables", ",", " ", 
   RowBox[{"\"\<Monitor\>\"", " ", "->", " ", "False"}]}], "]"}]], "Input",Exp\
ressionUUID->"1c04a903-1672-4244-b03f-6aa824527cb1"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Details", "Section",ExpressionUUID->"548f8226-04b7-411f-b472-c53381ee543f"],

Cell["Notation conversions", "Subsection",ExpressionUUID->"d74dcdb4-8971-4c92-bb0e-53d7775ca4c2"],

Cell["\<\
HyperIntica uses two internal representations for iterated integrals: Hlog[x, \
{letters}] (hyperlogarithms with explicit upper limit) and Mpl[{weights}, \
{args}] (multiple polylogarithms in the Li_{n_1,\[Ellipsis]}(z_1,\[Ellipsis]) \
convention). The following replacement rules convert between them: (see \
example below) These are used, for instance, when comparing results expressed \
in different bases or when interfacing with external tools that expect a \
specific notation. When integrating over [0,\[Infinity]), boundary \
contributions at 0 and \[Infinity] may arise as formal ZeroInfPeriod objects. \
The replacement rule (see example below) expresses these boundary periods in \
terms of Mpl values (typically multiple zeta values), allowing the full \
result to be written in a uniform notation.\
\>", "Text",ExpressionUUID->"73aabc62-2b14-4f0b-9978-ea98d2e5c410"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"expr", " ", "/.", " ", 
   RowBox[{"Hlog", " ", "->", " ", "HlogAsMpl"}]}], "   ", 
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{"Hlog", " ", "\\", "to"}], " ", "Mpl", " ", "notation"}], " ", 
   "*)"}]}], "\n", 
 RowBox[{"expr", " ", "/.", " ", 
  RowBox[{"Mpl", " ", "->", " ", "MplAsHlog", "    ", 
   RowBox[{"(*", " ", 
    RowBox[{
     RowBox[{"Mpl", " ", "\\", "to"}], " ", "Hlog", " ", "notation"}], " ", 
    "*)"}]}]}]}], "Input",ExpressionUUID->"76c7d9fc-6611-47f8-9225-\
07534b809989"],

Cell[BoxData[
 RowBox[{"expr", " ", "/.", " ", 
  RowBox[{"ZeroInfPeriod", " ", "->", " ", "ZeroInfPeriodAsMpl"}]}]], "Input",\
ExpressionUUID->"be3071e7-7179-498a-a288-48ee211738e8"]
}, Open  ]],


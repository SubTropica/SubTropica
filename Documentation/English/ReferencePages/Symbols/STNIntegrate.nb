Notebook[{

Cell[CellGroupData[{
Cell["STNIntegrate", "ObjectName",ExpressionUUID->"9e166465-3a86-4de0-959b-b80416f87c8a"],

Cell[BoxData[GridBox[{
   {Cell[TextData[{
     StyleBox["STNIntegrate", "TI"],
     " \[LineSeparator]STNIntegrate numerically evaluates integrals."
    }], "TableText",ExpressionUUID->"66faca73-19c8-49c2-829b-29d30f04fe97"]}
  },
  GridBoxAlignment->{"Columns" -> {{Left}}},
  GridBoxItemSize->{
   "Columns" -> {{Automatic}}, "Rows" -> {{Automatic}}}]], "Usage",
 CellID->1,ExpressionUUID->"e961e3bd-e56c-46e1-802e-bd3f64bd62ba"],

Cell["\<\
STNIntegrate numerically evaluates integrals. It accepts all the same input \
formats as STIntegrate (Forms~1--3), including generic parametric \
representations.\
\>", "Notes",ExpressionUUID->"159ef139-3f16-4b4d-9685-942d029942fb"],

Cell[BoxData[
 RowBox[{"STNIntegrate", "[", 
  RowBox[{"input", "\n", "    ", ",", " ", 
   RowBox[{"\"\<Method\>\"", "             ", "->", " ", "\"\<pySecDec\>\""}],
    "\n", "    ", ",", " ", 
   RowBox[{"\"\<Substitutions\>\"", "     ", "->", " ", 
    RowBox[{"{", "}"}]}], "\n", "    ", ",", " ", 
   RowBox[{"\"\<Order\>\"", "              ", "->", " ", "0"}], "\n", "    ", 
   ",", " ", 
   RowBox[{"\"\<MaxEval\>\"", "            ", "->", " ", 
    RowBox[{"10", "^", "7"}]}], "\n", "    ", ",", " ", 
   RowBox[{"\"\<Accuracy\>\"", "           ", "->", " ", 
    RowBox[{"10", "^", 
     RowBox[{"-", "4"}]}]}], "\n", "    ", ",", " ", 
   RowBox[{"\"\<Integrator\>\"", "         ", "->", " ", "\"\<Qmc\>\""}], 
   "\n", "    ", ",", " ", 
   RowBox[{"\"\<ContourDeformation\>\"", " ", "->", " ", "True"}], "\n", 
   "    ", ",", " ", 
   RowBox[{"\"\<Verbose\>\"", "            ", "->", " ", "False"}], "\n", 
   "    ", ",", " ", 
   RowBox[{"\"\<Dimension\>\"", "          ", "->", " ", 
    RowBox[{"4", " ", "-", " ", 
     RowBox[{"2", " ", "eps"}]}]}], "\n", "    ", ",", " ", 
   RowBox[{"\"\<Normalization\>\"", "      ", "->", " ", "Automatic"}], "\n", 
   "    ", ",", " ", 
   RowBox[{"\"\<Exponents\>\"", "          ", "->", " ", "Automatic"}], "\n", 
   "    ", ",", " ", 
   RowBox[{"\"\<Substitutions\>\"", "      ", "->", " ", 
    RowBox[{"{", "}"}]}], "\n", "    ", ",", " ", 
   RowBox[{"\"\<CacheDirectory\>\"", "     ", "->", " ", "Automatic"}]}], 
  "]"}]], "Input",ExpressionUUID->"ce4ee9be-f304-47ab-8b3c-c7ce2f90bb48"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Details", "Section",ExpressionUUID->"4aeed7f2-55f6-4e44-b9ec-fa328bfc731f"],

Cell["Options", "Subsection",ExpressionUUID->"d5633739-ef84-4e6d-aaeb-db0b091327b0"],

Cell["\<\
\"Method\" selects the backend: \"pySecDec\" (default), \"FIESTA\", \
\"AMFlow\" or \"feyntrop\". \"Substitutions\" specifies the numerical values \
for kinematic variables as a list of rules (e.g., {s12 -> -7, mm -> 3}). \
\"Order\" sets the \[CurlyEpsilon]-expansion depth. \"MaxEval\" caps the \
number of integrand evaluations. \"Integrator\" selects the integration \
algorithm: \"Qmc\" (default, quasi-Monte Carlo), \"Vegas\", or \"Disteval\". \
QMC is the default as it typically provides the fastest convergence.\
\>", "Text",ExpressionUUID->"dc7a2336-0a42-4631-9c3f-20c536951485"],

Cell["Return value", "Subsection",ExpressionUUID->"becd8e86-f256-45e1-bcd9-a978a1a3aa48"],

Cell["\<\
An Association with keys \"Value\" (the numerical result as a SeriesData), \
\"Error\" (integration uncertainties), \"Method\", \"Integrator\", \
\"Substitutions\", and \"Timing\" (wall-clock time in seconds).\
\>", "Text",ExpressionUUID->"2d5c6b8e-d907-472e-9b74-5232e04ebe49"]
}, Open  ]],


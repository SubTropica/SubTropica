Notebook[{

Cell[CellGroupData[{
Cell["STBrowser", "ObjectName",ExpressionUUID->"70c8fd15-1708-45d9-afb0-3b666cc38b83"],

Cell[BoxData[GridBox[{
   {Cell[TextData[{
     StyleBox["STBrowser[]", "TI"],
     " \[LineSeparator]starts the local SubTropica server (if it is not \
already running) and opens its URL in the default system browser. Returns \
Null on success; returns $Failed only if the server could not be started. No \
native viewer, no parallel kernels, no main polling loop \\[LongDash] the \
evaluation cell returns immediately and prints nothing. Idempotent: \
subsequent calls reuse the existing server and reopen the browser tab. Useful \
for library browsing, Review tool access, and diagram inspection while \
keeping the notebook kernel free for parallel work. Note: UI actions that \
would route back into Mathematica (e.g. running an integration from the \
diagram editor) will hang in this mode because no main loop is draining the \
IPC queue \\[LongDash] use STIntegrate[] for that. The URL is still available \
as $stServerURL if needed. Call STStop[] when done."
    }], "TableText",ExpressionUUID->"aa191885-0814-4e4e-ba92-65034b9d30ea"]}
  },
  GridBoxAlignment->{"Columns" -> {{Left}}},
  GridBoxItemSize->{
   "Columns" -> {{Automatic}}, "Rows" -> {{Automatic}}}]], "Usage",
 CellID->1,ExpressionUUID->"37fec32d-1a14-43cb-9e17-7d249985d7c8"]
}, Open  ]],

Cell[CellGroupData[{

Cell["See Also", "SeeAlsoSection",ExpressionUUID->"0ae240ae-2401-4fa7-b5cf-45fbc038506f"],

Cell[TextData[{
 Cell[BoxData[
  ButtonBox["STIntegrate",
   BaseStyle->"Link",
   ButtonData->"paclet:SubTropica/ref/STIntegrate"]], "InlineFormula",
  ExpressionUUID->"db715c63-8902-4664-9bb1-a4195e3e6ba6"],
 " \[EmptyVerySmallSquare] ",
 Cell[BoxData[
  ButtonBox["FeynmanIntegrate",
   BaseStyle->"Link",
   ButtonData->"paclet:SubTropica/ref/FeynmanIntegrate"]], "InlineFormula",
  ExpressionUUID->"71f44aa5-2132-482d-be48-5d540e0bff21"],
 " \[EmptyVerySmallSquare] ",
 Cell[BoxData[
  ButtonBox["STStop",
   BaseStyle->"Link",
   ButtonData->"paclet:SubTropica/ref/STStop"]], "InlineFormula",
  ExpressionUUID->"05d802f5-9bde-448c-b9e6-224a0877a978"]
}], "SeeAlso",ExpressionUUID->"8e189f1b-9b8f-4d85-a51a-6237d42de8b3"]

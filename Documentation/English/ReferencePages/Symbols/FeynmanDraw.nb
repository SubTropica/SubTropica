Notebook[{

Cell[CellGroupData[{
Cell["FeynmanDraw", "ObjectName",ExpressionUUID->"f37b52b9-7c62-4d30-9aff-82c83be1b703"],

Cell[BoxData[GridBox[{
   {Cell[TextData[{
     StyleBox["FeynmanDraw", "TI"],
     " \[LineSeparator]FeynmanDraw opens an interactive canvas for drawing a \
Feynman diagram and returns the resulting {edges, nodes} pair in the SOFIA / \
SubTropica convention. Usage: {edges, nodes} = FeynmanDraw. The returned pair \
can be passed directly to STIntegrate or visualized with FeynmanPlot."
    }], "TableText",ExpressionUUID->"3a48bfe1-080c-47cf-a1b5-ec34baf611ff"]}
  },
  GridBoxAlignment->{"Columns" -> {{Left}}},
  GridBoxItemSize->{
   "Columns" -> {{Automatic}}, "Rows" -> {{Automatic}}}]], "Usage",
 CellID->1,ExpressionUUID->"70445be4-30cb-4d31-8ba4-0016c835b048"]
}, Open  ]],


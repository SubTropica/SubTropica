Notebook[{

Cell[CellGroupData[{
Cell["STSubmitResult", "ObjectName",ExpressionUUID->"a48513c5-df72-4277-b7b7-9e53af5c2566"],

Cell[BoxData[GridBox[{
   {Cell[TextData[{
     StyleBox["STSubmitResult[]", "TI"],
     " \[LineSeparator]submits the most recent integration result to the \
central SubTropica library. No GitHub account required. Submissions are gated \
on numerical verification: if $integrationResult does not carry a passing \
STVerify record, STSubmitResult runs STVerify inline (1 kinematic point, \
pySecDec, Tolerance 10^-3) before submitting and aborts on failure."
    }], "TableText",ExpressionUUID->"bbe2368b-d394-48de-8005-a0b100c7f0bd"]}
  },
  GridBoxAlignment->{"Columns" -> {{Left}}},
  GridBoxItemSize->{
   "Columns" -> {{Automatic}}, "Rows" -> {{Automatic}}}]], "Usage",
 CellID->1,ExpressionUUID->"c3eb1402-9ef4-4ec3-9b5e-6f4aad6d4da0"]
}, Open  ]],


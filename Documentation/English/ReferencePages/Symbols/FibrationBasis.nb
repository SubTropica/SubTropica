Notebook[{

Cell[CellGroupData[{
Cell["FibrationBasis", "ObjectName",ExpressionUUID->"eddb4474-83c7-46d1-b7a0-0aa6ab456ab1"],

Cell[BoxData[GridBox[{
   {Cell[TextData[{
     StyleBox["FibrationBasis", "TI"],
     " \[LineSeparator]While HyperIntica is the main (analytic) integration \
routine working under the hood of the STIntegrate function, it can also be \
used as a standalone function."
    }], "TableText",ExpressionUUID->"c54e4634-9a9f-441e-ac7a-538be7a8e135"]}
  },
  GridBoxAlignment->{"Columns" -> {{Left}}},
  GridBoxItemSize->{
   "Columns" -> {{Automatic}}, "Rows" -> {{Automatic}}}]], "Usage",
 CellID->1,ExpressionUUID->"32874eb1-80a6-4933-84fe-d1c1c5998598"],

Cell["\<\
While HyperIntica is the main (analytic) integration routine working under \
the hood of the STIntegrate function, it can also be used as a standalone \
function. It evaluates iterated integrals \[Integral]_0^\[Infinity] \
\[Ellipsis] \[Integral]_0^\[Infinity] f\\, dx_1 \[Ellipsis] dx_n in  for \
expressions built from hyperlogarithms, polylogarithms, logarithms, and \
rational functions, returning results in terms of multi-zeta values and \
hyperlogarithms in the original integrand f parameters (if any). The syntax \
is: (see example below)\
\>", "Notes",ExpressionUUID->"4496424e-8f25-4824-a616-3b8d4c24bcca"],

Cell[BoxData[
 RowBox[{"HyperIntica", "[", 
  RowBox[{"integrand", ",", " ", "variables", ",", " ", 
   RowBox[{"\"\<Monitor\>\"", " ", "->", " ", "False"}]}], "]"}]], "Input",Exp\
ressionUUID->"054da383-1de4-4a16-b4fd-e4bce8261384"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Details", "Section",ExpressionUUID->"694349c0-c6e5-4993-b834-2fc2c0bb85a9"],

Cell["Fibration basis", "Subsection",ExpressionUUID->"a1704612-551a-4a77-9af6-de49e008dbac"],

Cell["\<\
FibrationBasis[expr, variables] rewrites an expression in a fibration basis, \
often making non-trivial functional identities between hyperlogarithms \
manifest. The argument expr accepts a symbolic expression (e.g., PolyLog or \
Hlog). The variables argument defines the fibration order x_1 \[Precedes] x_2 \
\[Precedes] \[Ellipsis] \[Precedes] x_n, where w_j = \
w_j(x_1,\[Ellipsis],x_n). The output can vary significantly with this \
ordering. The decomposition is based on the shuffle identity introduced \
earlier in ,\
\>", "Text",ExpressionUUID->"453882ad-2afe-410c-b537-9d332c569791"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{"Single", "-", 
    RowBox[{"variable", ":", " ", 
     RowBox[{
      RowBox[{"Li", "\\", "textcolor"}], 
      RowBox[{"{", "gray", "}"}], 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"{", "}"}], "_", "5"}], "}"}], 
      RowBox[{"(", 
       RowBox[{
        RowBox[{"-", "1"}], "/", "z"}], ")"}], " ", "expressed", " ", "as", " ",
       "sum", " ", "of", "  ", "c_w", " ", 
      RowBox[{"Hlog", "[", 
       RowBox[{"z", ",", " ", "w"}], "]"}], "  ", "with", " ", "MZV", " ", 
      "coefficient", " ", "c_w"}]}]}], " ", "*)"}], "\n", "\t", 
  RowBox[{
   RowBox[{"FibrationBasis", "[", 
    RowBox[{
     RowBox[{"PolyLog", "[", 
      RowBox[{"5", ",", " ", 
       RowBox[{
        RowBox[{"-", "1"}], "/", "z"}]}], "]"}], ",", " ", 
     RowBox[{"{", "z", "}"}]}], "]"}], "\n", "\t", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{"-", 
      RowBox[{"Hlog", "[", 
       RowBox[{"z", ",", " ", 
        RowBox[{"{", 
         RowBox[{"0", ",", " ", "0", ",", " ", "0", ",", " ", "0", ",", " ", 
          RowBox[{"-", "1"}]}], "}"}]}], "]"}]}], " ", "+", " ", 
     RowBox[{"Hlog", "[", 
      RowBox[{"z", ",", " ", 
       RowBox[{"{", 
        RowBox[{
        "0", ",", " ", "0", ",", " ", "0", ",", " ", "0", ",", " ", "0"}], 
        "}"}]}], "]"}], " ", "+", " ", 
     RowBox[{
      RowBox[{"Hlog", "[", 
       RowBox[{"z", ",", " ", 
        RowBox[{"{", 
         RowBox[{"0", ",", " ", "0", ",", " ", "0"}], "}"}]}], "]"}], "*", 
      RowBox[{"mzv", "[", "2", "]"}]}], " ", "+", " ", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{"7", "*", 
        RowBox[{"Hlog", "[", 
         RowBox[{"z", ",", " ", 
          RowBox[{"{", "0", "}"}]}], "]"}], "*", 
        RowBox[{
         RowBox[{"mzv", "[", "2", "]"}], "^", "2"}]}], ")"}], "/", "10"}]}], 
    "*)"}], "\n", "\t", "\n", "\t", 
   RowBox[{"(*", " ", 
    RowBox[{"Two", "-", 
     RowBox[{"variable", ":"}]}], " ", "*)"}], "\n", "\t", 
   RowBox[{"FibrationBasis", "[", 
    RowBox[{
     RowBox[{"Hlog", "[", 
      RowBox[{"1", ",", " ", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"1", " ", "+", " ", "x"}], ",", " ", 
         RowBox[{"1", " ", "+", " ", "y"}]}], "}"}]}], "]"}], ",", " ", 
     RowBox[{"{", 
      RowBox[{"x", ",", " ", "y"}], "}"}]}], "]"}], "\n", "\t", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{"-", 
      RowBox[{"Hlog", "[", 
       RowBox[{"x", ",", " ", 
        RowBox[{"{", 
         RowBox[{"y", ",", " ", 
          RowBox[{"-", "1"}]}], "}"}]}], "]"}]}], " ", "+", " ", 
     RowBox[{"Hlog", "[", 
      RowBox[{"x", ",", " ", 
       RowBox[{"{", 
        RowBox[{"y", ",", " ", "0"}], "}"}]}], "]"}], " ", "-", " ", 
     RowBox[{
      RowBox[{"Hlog", "[", 
       RowBox[{"x", ",", " ", 
        RowBox[{"{", "0", "}"}]}], "]"}], " ", 
      RowBox[{"Hlog", "[", 
       RowBox[{"y", ",", " ", 
        RowBox[{"{", 
         RowBox[{"-", "1"}], "}"}]}], "]"}]}], " ", "+", "\n", "\t", 
     RowBox[{
      RowBox[{"Hlog", "[", 
       RowBox[{"x", ",", " ", 
        RowBox[{"{", "y", "}"}]}], "]"}], " ", 
      RowBox[{"Hlog", "[", 
       RowBox[{"y", ",", " ", 
        RowBox[{"{", 
         RowBox[{"-", "1"}], "}"}]}], "]"}]}], " ", "+", " ", 
     RowBox[{
      RowBox[{"Hlog", "[", 
       RowBox[{"x", ",", " ", 
        RowBox[{"{", "0", "}"}]}], "]"}], " ", 
      RowBox[{"Hlog", "[", 
       RowBox[{"y", ",", " ", 
        RowBox[{"{", "0", "}"}]}], "]"}]}], " ", "-", "\n", "\t", 
     RowBox[{
      RowBox[{"Hlog", "[", 
       RowBox[{"x", ",", " ", 
        RowBox[{"{", "y", "}"}]}], "]"}], " ", 
      RowBox[{"Hlog", "[", 
       RowBox[{"y", ",", " ", 
        RowBox[{"{", "0", "}"}]}], "]"}]}], " ", "+", " ", 
     RowBox[{"Hlog", "[", 
      RowBox[{"y", ",", " ", 
       RowBox[{"{", 
        RowBox[{"0", ",", " ", 
         RowBox[{"-", "1"}]}], "}"}]}], "]"}], " ", "-", " ", 
     RowBox[{"Hlog", "[", 
      RowBox[{"y", ",", " ", 
       RowBox[{"{", 
        RowBox[{"0", ",", " ", "0"}], "}"}]}], "]"}], " ", "-", "\n", "\t", 
     RowBox[{"mzv", "[", "2", "]"}]}], "*)"}]}]}]], "Input",ExpressionUUID->\
"c603e97c-3d36-48fc-a5fd-fe7240e28968"]
}, Open  ]],


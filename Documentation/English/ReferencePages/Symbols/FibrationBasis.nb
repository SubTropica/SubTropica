Notebook[{

Cell[CellGroupData[{
Cell["FibrationBasis", "ObjectName",ExpressionUUID->"4c654af2-23a5-49f8-bf94-10e1d6e70ef2"],

Cell[BoxData[GridBox[{
   {Cell[TextData[{
     StyleBox["FibrationBasis", "TI"],
     " \[LineSeparator]While HyperIntica is the main (analytic) integration \
routine working under the hood of the STIntegrate function, it can also be \
used as a standalone function."
    }], "TableText",ExpressionUUID->"153f1ca7-cbf2-44cf-a5ef-4bceee63d7af"]}
  },
  GridBoxAlignment->{"Columns" -> {{Left}}},
  GridBoxItemSize->{
   "Columns" -> {{Automatic}}, "Rows" -> {{Automatic}}}]], "Usage",
 CellID->1,ExpressionUUID->"aded8696-6f6a-45dd-8f1a-21616671cee0"],

Cell["\<\
While HyperIntica is the main (analytic) integration routine working under \
the hood of the STIntegrate function, it can also be used as a standalone \
function. It evaluates iterated integrals \[Integral]_0^\[Infinity] \
\[Ellipsis] \[Integral]_0^\[Infinity] f\\, dx_1 \[Ellipsis] dx_n in  for \
expressions built from hyperlogarithms, polylogarithms, logarithms, and \
rational functions, returning results in terms of multi-zeta values and \
hyperlogarithms in the original integrand f parameters (if any). The syntax \
is: (see example below)\
\>", "Notes",ExpressionUUID->"33e0b9c1-c52c-43d6-b566-b86b9985d4e7"],

Cell[BoxData[
 RowBox[{"HyperIntica", "[", 
  RowBox[{"integrand", ",", " ", "variables", ",", " ", 
   RowBox[{"\"\<Monitor\>\"", " ", "->", " ", "False"}]}], "]"}]], "Input",Exp\
ressionUUID->"92c6f01b-1b08-41c0-bee1-1caed3bb15bd"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Details", "Section",ExpressionUUID->"8a709a85-92d1-4233-82b4-bf5ab14307de"],

Cell["Fibration basis", "Subsection",ExpressionUUID->"b99f00a5-ac36-4cd3-83ac-07429ab273ad"],

Cell["\<\
FibrationBasis[expr, variables] rewrites an expression in a fibration basis, \
often making non-trivial functional identities between hyperlogarithms \
manifest. The argument expr accepts a symbolic expression (e.g., PolyLog or \
Hlog). The variables argument defines the fibration order x_1 \[Precedes] x_2 \
\[Precedes] \[Ellipsis] \[Precedes] x_n, where w_j = \
w_j(x_1,\[Ellipsis],x_n). The output can vary significantly with this \
ordering. The decomposition is based on the shuffle identity introduced \
earlier in ,\
\>", "Text",ExpressionUUID->"e8a3153e-97a8-4173-a271-e4b4b67458c6"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{"Single", "-", 
    RowBox[{"variable", ":", " ", 
     RowBox[{
      RowBox[{"Li", "\\", "textcolor"}], 
      RowBox[{"{", "gray", "}"}], 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"{", "}"}], "_", "5"}], "}"}], 
      RowBox[{"(", 
       RowBox[{
        RowBox[{"-", "1"}], "/", "z"}], ")"}], " ", "expressed", " ", "as", " ",
       "sum", " ", "of", "  ", "c_w", " ", 
      RowBox[{"Hlog", "[", 
       RowBox[{"z", ",", " ", "w"}], "]"}], "  ", "with", " ", "MZV", " ", 
      "coefficient", " ", "c_w"}]}]}], " ", "*)"}], "\n", "\t", 
  RowBox[{
   RowBox[{"FibrationBasis", "[", 
    RowBox[{
     RowBox[{"PolyLog", "[", 
      RowBox[{"5", ",", " ", 
       RowBox[{
        RowBox[{"-", "1"}], "/", "z"}]}], "]"}], ",", " ", 
     RowBox[{"{", "z", "}"}]}], "]"}], "\n", "\t", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{"-", 
      RowBox[{"Hlog", "[", 
       RowBox[{"z", ",", " ", 
        RowBox[{"{", 
         RowBox[{"0", ",", " ", "0", ",", " ", "0", ",", " ", "0", ",", " ", 
          RowBox[{"-", "1"}]}], "}"}]}], "]"}]}], " ", "+", " ", 
     RowBox[{"Hlog", "[", 
      RowBox[{"z", ",", " ", 
       RowBox[{"{", 
        RowBox[{
        "0", ",", " ", "0", ",", " ", "0", ",", " ", "0", ",", " ", "0"}], 
        "}"}]}], "]"}], " ", "+", " ", 
     RowBox[{
      RowBox[{"Hlog", "[", 
       RowBox[{"z", ",", " ", 
        RowBox[{"{", 
         RowBox[{"0", ",", " ", "0", ",", " ", "0"}], "}"}]}], "]"}], "*", 
      RowBox[{"mzv", "[", "2", "]"}]}], " ", "+", " ", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{"7", "*", 
        RowBox[{"Hlog", "[", 
         RowBox[{"z", ",", " ", 
          RowBox[{"{", "0", "}"}]}], "]"}], "*", 
        RowBox[{
         RowBox[{"mzv", "[", "2", "]"}], "^", "2"}]}], ")"}], "/", "10"}]}], 
    "*)"}], "\n", "\t", "\n", "\t", 
   RowBox[{"(*", " ", 
    RowBox[{"Two", "-", 
     RowBox[{"variable", ":"}]}], " ", "*)"}], "\n", "\t", 
   RowBox[{"FibrationBasis", "[", 
    RowBox[{
     RowBox[{"Hlog", "[", 
      RowBox[{"1", ",", " ", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"1", " ", "+", " ", "x"}], ",", " ", 
         RowBox[{"1", " ", "+", " ", "y"}]}], "}"}]}], "]"}], ",", " ", 
     RowBox[{"{", 
      RowBox[{"x", ",", " ", "y"}], "}"}]}], "]"}], "\n", "\t", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{"-", 
      RowBox[{"Hlog", "[", 
       RowBox[{"x", ",", " ", 
        RowBox[{"{", 
         RowBox[{"y", ",", " ", 
          RowBox[{"-", "1"}]}], "}"}]}], "]"}]}], " ", "+", " ", 
     RowBox[{"Hlog", "[", 
      RowBox[{"x", ",", " ", 
       RowBox[{"{", 
        RowBox[{"y", ",", " ", "0"}], "}"}]}], "]"}], " ", "-", " ", 
     RowBox[{
      RowBox[{"Hlog", "[", 
       RowBox[{"x", ",", " ", 
        RowBox[{"{", "0", "}"}]}], "]"}], " ", 
      RowBox[{"Hlog", "[", 
       RowBox[{"y", ",", " ", 
        RowBox[{"{", 
         RowBox[{"-", "1"}], "}"}]}], "]"}]}], " ", "+", "\n", "\t", 
     RowBox[{
      RowBox[{"Hlog", "[", 
       RowBox[{"x", ",", " ", 
        RowBox[{"{", "y", "}"}]}], "]"}], " ", 
      RowBox[{"Hlog", "[", 
       RowBox[{"y", ",", " ", 
        RowBox[{"{", 
         RowBox[{"-", "1"}], "}"}]}], "]"}]}], " ", "+", " ", 
     RowBox[{
      RowBox[{"Hlog", "[", 
       RowBox[{"x", ",", " ", 
        RowBox[{"{", "0", "}"}]}], "]"}], " ", 
      RowBox[{"Hlog", "[", 
       RowBox[{"y", ",", " ", 
        RowBox[{"{", "0", "}"}]}], "]"}]}], " ", "-", "\n", "\t", 
     RowBox[{
      RowBox[{"Hlog", "[", 
       RowBox[{"x", ",", " ", 
        RowBox[{"{", "y", "}"}]}], "]"}], " ", 
      RowBox[{"Hlog", "[", 
       RowBox[{"y", ",", " ", 
        RowBox[{"{", "0", "}"}]}], "]"}]}], " ", "+", " ", 
     RowBox[{"Hlog", "[", 
      RowBox[{"y", ",", " ", 
       RowBox[{"{", 
        RowBox[{"0", ",", " ", 
         RowBox[{"-", "1"}]}], "}"}]}], "]"}], " ", "-", " ", 
     RowBox[{"Hlog", "[", 
      RowBox[{"y", ",", " ", 
       RowBox[{"{", 
        RowBox[{"0", ",", " ", "0"}], "}"}]}], "]"}], " ", "-", "\n", "\t", 
     RowBox[{"mzv", "[", "2", "]"}]}], "*)"}]}]}]], "Input",ExpressionUUID->\
"c468f671-d620-4402-bbc7-3bc739145220"]

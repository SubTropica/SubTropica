Notebook[{

Cell[CellGroupData[{
Cell["FibrationBasis", "ObjectName",ExpressionUUID->"980b1f71-2358-48cf-bf27-a68ea5eba9fe"],

Cell[BoxData[GridBox[{
   {Cell[TextData[{
     StyleBox["FibrationBasis", "TI"],
     " \[LineSeparator]While HyperIntica is the main (analytic) integration \
routine working under the hood of the STIntegrate function, it can also be \
used as a standalone function."
    }], "TableText",ExpressionUUID->"7f6d055a-f230-436d-9397-abc21dfac8c0"]}
  },
  GridBoxAlignment->{"Columns" -> {{Left}}},
  GridBoxItemSize->{
   "Columns" -> {{Automatic}}, "Rows" -> {{Automatic}}}]], "Usage",
 CellID->1,ExpressionUUID->"88c199b4-dd38-4427-b140-491b14227b33"],

Cell["\<\
While HyperIntica is the main (analytic) integration routine working under \
the hood of the STIntegrate function, it can also be used as a standalone \
function. It evaluates iterated integrals \[Integral]_0^\[Infinity] \
\[Ellipsis] \[Integral]_0^\[Infinity] f\\, dx_1 \[Ellipsis] dx_n in  for \
expressions built from hyperlogarithms, polylogarithms, logarithms, and \
rational functions, returning results in terms of multi-zeta values and \
hyperlogarithms in the original integrand f parameters (if any). The syntax \
is: (see example below)\
\>", "Notes",ExpressionUUID->"69130bdb-2c4f-4c32-a436-45c7d77ff59e"],

Cell[BoxData[
 RowBox[{"HyperIntica", "[", 
  RowBox[{"integrand", ",", " ", "variables", ",", " ", 
   RowBox[{"\"\<Monitor\>\"", " ", "->", " ", "False"}]}], "]"}]], "Input",Exp\
ressionUUID->"b3b9e1bc-3fb3-4377-8fa5-78b95e7035b2"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Details", "Section",ExpressionUUID->"af65294a-ebc4-45d2-a922-c5ff42dbc6c0"],

Cell["Fibration basis", "Subsection",ExpressionUUID->"d33e3f17-4e08-476f-9714-7a945c0a9f1c"],

Cell["\<\
FibrationBasis[expr, variables] rewrites an expression in a fibration basis, \
often making non-trivial functional identities between hyperlogarithms \
manifest. The argument expr accepts a symbolic expression (e.g., PolyLog or \
Hlog). The variables argument defines the fibration order x_1 \[Precedes] x_2 \
\[Precedes] \[Ellipsis] \[Precedes] x_n, where w_j = \
w_j(x_1,\[Ellipsis],x_n). The output can vary significantly with this \
ordering. The decomposition is based on the shuffle identity introduced \
earlier in ,\
\>", "Text",ExpressionUUID->"5028365e-11c0-495b-9332-ee5eced1125f"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{"Single", "-", 
    RowBox[{"variable", ":", " ", 
     RowBox[{
      RowBox[{"Li", "\\", "textcolor"}], 
      RowBox[{"{", "gray", "}"}], 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"{", "}"}], "_", "5"}], "}"}], 
      RowBox[{"(", 
       RowBox[{
        RowBox[{"-", "1"}], "/", "z"}], ")"}], " ", "expressed", " ", "as", " ",
       "sum", " ", "of", "  ", "c_w", " ", 
      RowBox[{"Hlog", "[", 
       RowBox[{"z", ",", " ", "w"}], "]"}], "  ", "with", " ", "MZV", " ", 
      "coefficient", " ", "c_w"}]}]}], " ", "*)"}], "\n", "\t", 
  RowBox[{
   RowBox[{"FibrationBasis", "[", 
    RowBox[{
     RowBox[{"PolyLog", "[", 
      RowBox[{"5", ",", " ", 
       RowBox[{
        RowBox[{"-", "1"}], "/", "z"}]}], "]"}], ",", " ", 
     RowBox[{"{", "z", "}"}]}], "]"}], "\n", "\t", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{"-", 
      RowBox[{"Hlog", "[", 
       RowBox[{"z", ",", " ", 
        RowBox[{"{", 
         RowBox[{"0", ",", " ", "0", ",", " ", "0", ",", " ", "0", ",", " ", 
          RowBox[{"-", "1"}]}], "}"}]}], "]"}]}], " ", "+", " ", 
     RowBox[{"Hlog", "[", 
      RowBox[{"z", ",", " ", 
       RowBox[{"{", 
        RowBox[{
        "0", ",", " ", "0", ",", " ", "0", ",", " ", "0", ",", " ", "0"}], 
        "}"}]}], "]"}], " ", "+", " ", 
     RowBox[{
      RowBox[{"Hlog", "[", 
       RowBox[{"z", ",", " ", 
        RowBox[{"{", 
         RowBox[{"0", ",", " ", "0", ",", " ", "0"}], "}"}]}], "]"}], "*", 
      RowBox[{"mzv", "[", "2", "]"}]}], " ", "+", " ", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{"7", "*", 
        RowBox[{"Hlog", "[", 
         RowBox[{"z", ",", " ", 
          RowBox[{"{", "0", "}"}]}], "]"}], "*", 
        RowBox[{
         RowBox[{"mzv", "[", "2", "]"}], "^", "2"}]}], ")"}], "/", "10"}]}], 
    "*)"}], "\n", "\t", "\n", "\t", 
   RowBox[{"(*", " ", 
    RowBox[{"Two", "-", 
     RowBox[{"variable", ":"}]}], " ", "*)"}], "\n", "\t", 
   RowBox[{"FibrationBasis", "[", 
    RowBox[{
     RowBox[{"Hlog", "[", 
      RowBox[{"1", ",", " ", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"1", " ", "+", " ", "x"}], ",", " ", 
         RowBox[{"1", " ", "+", " ", "y"}]}], "}"}]}], "]"}], ",", " ", 
     RowBox[{"{", 
      RowBox[{"x", ",", " ", "y"}], "}"}]}], "]"}], "\n", "\t", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{"-", 
      RowBox[{"Hlog", "[", 
       RowBox[{"x", ",", " ", 
        RowBox[{"{", 
         RowBox[{"y", ",", " ", 
          RowBox[{"-", "1"}]}], "}"}]}], "]"}]}], " ", "+", " ", 
     RowBox[{"Hlog", "[", 
      RowBox[{"x", ",", " ", 
       RowBox[{"{", 
        RowBox[{"y", ",", " ", "0"}], "}"}]}], "]"}], " ", "-", " ", 
     RowBox[{
      RowBox[{"Hlog", "[", 
       RowBox[{"x", ",", " ", 
        RowBox[{"{", "0", "}"}]}], "]"}], " ", 
      RowBox[{"Hlog", "[", 
       RowBox[{"y", ",", " ", 
        RowBox[{"{", 
         RowBox[{"-", "1"}], "}"}]}], "]"}]}], " ", "+", "\n", "\t", 
     RowBox[{
      RowBox[{"Hlog", "[", 
       RowBox[{"x", ",", " ", 
        RowBox[{"{", "y", "}"}]}], "]"}], " ", 
      RowBox[{"Hlog", "[", 
       RowBox[{"y", ",", " ", 
        RowBox[{"{", 
         RowBox[{"-", "1"}], "}"}]}], "]"}]}], " ", "+", " ", 
     RowBox[{
      RowBox[{"Hlog", "[", 
       RowBox[{"x", ",", " ", 
        RowBox[{"{", "0", "}"}]}], "]"}], " ", 
      RowBox[{"Hlog", "[", 
       RowBox[{"y", ",", " ", 
        RowBox[{"{", "0", "}"}]}], "]"}]}], " ", "-", "\n", "\t", 
     RowBox[{
      RowBox[{"Hlog", "[", 
       RowBox[{"x", ",", " ", 
        RowBox[{"{", "y", "}"}]}], "]"}], " ", 
      RowBox[{"Hlog", "[", 
       RowBox[{"y", ",", " ", 
        RowBox[{"{", "0", "}"}]}], "]"}]}], " ", "+", " ", 
     RowBox[{"Hlog", "[", 
      RowBox[{"y", ",", " ", 
       RowBox[{"{", 
        RowBox[{"0", ",", " ", 
         RowBox[{"-", "1"}]}], "}"}]}], "]"}], " ", "-", " ", 
     RowBox[{"Hlog", "[", 
      RowBox[{"y", ",", " ", 
       RowBox[{"{", 
        RowBox[{"0", ",", " ", "0"}], "}"}]}], "]"}], " ", "-", "\n", "\t", 
     RowBox[{"mzv", "[", "2", "]"}]}], "*)"}]}]}]], "Input",ExpressionUUID->\
"c2f2bfd2-4931-4d59-82a4-888bd2462268"]

Notebook[{

Cell[CellGroupData[{
Cell["STEspressoFubini", "ObjectName",ExpressionUUID->"c8b668aa-f1ce-4b34-8168-e3810ff674d9"],

Cell[BoxData[GridBox[{
   {Cell[TextData[{
     StyleBox["STEspressoFubini", "TI"],
     " \[LineSeparator]~."
    }], "TableText",ExpressionUUID->"412ed8b2-451e-45fe-bbb7-9268d7bff4b5"]}
  },
  GridBoxAlignment->{"Columns" -> {{Left}}},
  GridBoxItemSize->{
   "Columns" -> {{Automatic}}, "Rows" -> {{Automatic}}}]], "Usage",
 CellID->1,ExpressionUUID->"b288d1ed-da63-4cdb-ba8b-ccfc4c826d55"],

Cell["\<\
STEspressoFubini finds a linearly reducible integration order for a given set \
of polynomials, using an optimized implementation of the Fubini reduction \
algorithm discussed in Sec.~. It is called internally by STIntegrate to \
determine valid integration orders before dispatching to HyperIntica. The \
syntax is: (see example below)\
\>", "Notes",ExpressionUUID->"8190df17-6db4-4d23-88af-611a1d911b49"],

Cell[BoxData[
 RowBox[{"STEspressoFubini", "[", 
  RowBox[{"groupPolynomials", ",", " ", "variables", "\n", "\t", ",", " ", 
   RowBox[{"\"\<SolverBound\>\"", " ", "->", " ", 
    RowBox[{"10", "^", "9"}]}], "\n", "\t", ",", " ", 
   RowBox[{"\"\<FindRoots\>\"", " ", "->", " ", "False"}], "\n", "\t", ",", 
   " ", 
   RowBox[{"\"\<Heuristic\>\"", " ", "->", " ", "\"\<LeafCountLinear\>\""}]}],
   "]"}]], "Input",ExpressionUUID->"db726cd8-09c7-45b2-a1e6-499675f3bf8e"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Details", "Section",ExpressionUUID->"f2a96899-ae6c-4548-9103-b34508658fde"],

Cell["Arguments", "Subsection",ExpressionUUID->"e08e29e5-4ce3-45ce-9d43-ec177acd13a4"],

Cell["\<\
The argument groupPolynomials is a list of polynomial lists (e.g., ), one per \
counter-term integrand; the algorithm finds an order that is linearly \
reducible simultaneously for all groups. The variables is the list of \
integration variables. The function returns a permutation of variables giving \
a valid integration order, or NOLR if none is found.\
\>", "Text",ExpressionUUID->"c4f9f61f-5450-4eb6-875d-40c138bb9c4d"],

Cell["Options", "Subsection",ExpressionUUID->"634f135b-4f9e-4f93-bcc6-48f390338048"],

Cell["\<\
SolverBound (default 10^9) caps the number of terms in polynomials during \
discriminant and resultant computations; polynomials above this bound are \
skipped, which can speed up the search at the cost of potentially missing \
some valid orders. FindRoots -> True attempts to factor univariate \
polynomials of degree greater than one by introducing auxiliary root \
variables, extending the class of linearly reducible integrals at the cost of \
increased complexity (default False).\
\>", "Text",ExpressionUUID->"9032d52c-5812-4d47-b871-94a9b866ffbc"]
}, Open  ]],

